<template>
  <view v-if="visible" class="dialog-mask" @tap="onMaskTap">
    <view class="dialog-card" @tap.stop="">
      <view class="dialog-header">
        <text class="dialog-title">编辑触发规则</text>
        <text v-if="isDefault" class="dialog-subtitle">系统默认规则</text>
      </view>

      <scroll-view class="dialog-body" scroll-y="true">
        <view class="field-group">
          <text class="field-label">微动作</text>
          <view v-if="isDefault" class="field-static">
            <text class="field-static-text">任意动作（由算法推荐）</text>
          </view>
          <view v-else class="action-picker">
            <view
              v-for="(a, i) in actions"
              :key="'act-' + i"
              class="action-item"
              :class="a.id === draftActionId ? 'action-item-active' : ''"
              @tap="onPickAction(a.id)"
            >
              <text class="action-name">{{ a.name }}</text>
              <text class="action-cat">{{ a.category }}</text>
            </view>
          </view>
        </view>

        <view class="field-group">
          <text class="field-label">触发阈值</text>
          <view class="threshold-row">
            <text class="field-value">{{ draftThreshold }} 分钟</text>
            <view class="stepper">
              <view class="stepper-btn" @tap="onDecStep"><text class="stepper-text">-</text></view>
              <view class="stepper-btn" @tap="onIncStep"><text class="stepper-text">+</text></view>
            </view>
          </view>
          <text class="field-hint">使用同一应用达到该时长后触发</text>
        </view>

        <view class="field-group">
          <text class="field-label">生效时段</text>
          <view class="time-row">
            <view class="time-pill" :class="!draftTimeEnabled ? 'time-pill-active' : ''" @tap="onToggleTimeWindow(false)">
              <text class="time-pill-text">全天</text>
            </view>
            <view class="time-pill" :class="draftTimeEnabled ? 'time-pill-active' : ''" @tap="onToggleTimeWindow(true)">
              <text class="time-pill-text">自定义</text>
            </view>
          </view>
          <view v-if="draftTimeEnabled" class="time-inputs">
            <view class="time-input">
              <text class="time-input-label">起</text>
              <view class="stepper stepper-sm">
                <view class="stepper-btn" @tap="onDecStart"><text class="stepper-text">-</text></view>
                <text class="time-input-val">{{ pad2(draftStartHour) }}:00</text>
                <view class="stepper-btn" @tap="onIncStart"><text class="stepper-text">+</text></view>
              </view>
            </view>
            <view class="time-input">
              <text class="time-input-label">止</text>
              <view class="stepper stepper-sm">
                <view class="stepper-btn" @tap="onDecEnd"><text class="stepper-text">-</text></view>
                <text class="time-input-val">{{ pad2(draftEndHour) }}:00</text>
                <view class="stepper-btn" @tap="onIncEnd"><text class="stepper-text">+</text></view>
              </view>
            </view>
          </view>
        </view>

        <view v-if="!isDefault" class="field-group">
          <text class="field-label">指定 App</text>
          <text class="field-hint">留空表示所有 App 触发，每行一个包名</text>
          <textarea
            class="apps-area"
            v-model="draftAppsText"
            placeholder="com.tencent.mm&#10;com.android.chrome"
            auto-height="true"
          />
        </view>

        <view v-if="!isDefault" class="field-group">
          <text class="field-label">触发强度</text>
          <view class="level-row">
            <view class="level-pill" :class="draftLevel == 'gentle' ? 'level-pill-active' : ''" @tap="onPickLevel('gentle')">
              <text class="level-pill-text">温和</text>
            </view>
            <view class="level-pill" :class="draftLevel == 'strong' ? 'level-pill-active' : ''" @tap="onPickLevel('strong')">
              <text class="level-pill-text">强烈</text>
            </view>
          </view>
        </view>

        <view class="field-group">
          <view class="enable-row">
            <text class="field-label">启用此规则</text>
            <switch :checked="draftEnabled" @change="onEnabledChange" />
          </view>
        </view>
      </scroll-view>

      <view class="dialog-footer">
        <view v-if="!isDefault" class="btn btn-danger" @tap="onDelete">
          <text class="btn-text btn-text-danger">删除</text>
        </view>
        <view class="btn btn-ghost" @tap="onCancel">
          <text class="btn-text">取消</text>
        </view>
        <view class="btn btn-primary" @tap="onSave">
          <text class="btn-text btn-text-primary">保存</text>
        </view>
      </view>
    </view>
  </view>
</template>

<script setup lang="uts">
import { ALL_ACTIONS, getActionById } from '../constants/Actions'
import { PersistedEffectiveRule } from '../models/PersistedEffectiveRule'
import { TimeWindow, TriggerLevel } from '../models/EffectiveTriggerRule'

const props = withDefaults(defineProps<{
  visible: boolean
  ruleJson: string
}>(), {
  visible: false,
  ruleJson: ''
})

const emit = defineEmits<{
  (e: 'close'): void
  (e: 'save', rule: PersistedEffectiveRule): void
  (e: 'delete', id: number): void
}>()

const actions = ALL_ACTIONS

function pad2(n: number): string {
  if (n < 10) return '0' + n
  return '' + n
}

let draftActionId: string = ''
let draftThreshold: number = 60
let draftTimeEnabled: boolean = false
let draftStartHour: number = 9
let draftEndHour: number = 22
let draftAppsText: string = ''
let draftLevel: TriggerLevel = 'gentle'
let draftEnabled: boolean = true
let isDefault: boolean = false
let ruleId: number = 0
let ruleSource: 'user' | 'llm' | 'system' = 'user'
let ruleCreatedAt: number = 0
let ruleSourceHistoryId: number | null = null
let ruleExpiresAt: number | null = null

function resetDraft(): void {
  // 解析 ruleJson（基础类型 prop 无 reactive 包装问题，AGENTS §13/§49）
  if (props.ruleJson.length < 1) {
    draftActionId = ''
    draftThreshold = 60
    draftTimeEnabled = false
    draftStartHour = 9
    draftEndHour = 22
    draftAppsText = ''
    draftLevel = 'gentle'
    draftEnabled = true
    isDefault = false
    ruleId = 0
    ruleSource = 'user'
    ruleCreatedAt = Math.floor(Date.now() / 1000)
    ruleSourceHistoryId = null
    ruleExpiresAt = null
    return
  }
  const r: PersistedEffectiveRule = JSON.parse(props.ruleJson) as PersistedEffectiveRule
  ruleId = r.id
  isDefault = r.source == 'system'
  draftActionId = r.actionId
  draftThreshold = r.timeThresholdMinutes
  draftTimeEnabled = r.timeWindow != null
  if (r.timeWindow != null) {
    const sh = parseInt(r.timeWindow.start.split(':')[0] as string)
    const eh = parseInt(r.timeWindow.end.split(':')[0] as string)
    draftStartHour = isNaN(sh) ? 9 : sh
    draftEndHour = isNaN(eh) ? 22 : eh
  } else {
    draftStartHour = 9
    draftEndHour = 22
  }
  draftAppsText = r.appPackages.join('\n')
  draftLevel = r.triggerLevel
  draftEnabled = r.enabled
  ruleSource = r.source
  ruleCreatedAt = r.createdAt
  ruleSourceHistoryId = r.sourceHistoryId
  ruleExpiresAt = r.expiresAt
}

function onMaskTap(): void {
  emit('close')
}

function onCancel(): void {
  emit('close')
}

function onPickAction(id: string): void {
  if (isDefault) return
  draftActionId = id
}

function onDecStep(): void {
  if (draftThreshold > 5) draftThreshold = draftThreshold - 5
}

function onIncStep(): void {
  if (draftThreshold < 240) draftThreshold = draftThreshold + 5
}

function onToggleTimeWindow(enabled: boolean): void {
  draftTimeEnabled = enabled
}

function onDecStart(): void {
  if (draftStartHour > 0) draftStartHour = draftStartHour - 1
}

function onIncStart(): void {
  if (draftStartHour < 23) draftStartHour = draftStartHour + 1
}

function onDecEnd(): void {
  if (draftEndHour > 0) draftEndHour = draftEndHour - 1
}

function onIncEnd(): void {
  if (draftEndHour < 23) draftEndHour = draftEndHour + 1
}

function onPickLevel(lv: string): void {
  if (isDefault) return
  draftLevel = lv
}

function onEnabledChange(e: any): void {
  try {
    const obj = e as UTSJSONObject
    if (obj == null) return
    const v = obj['detail']
    if (v == null) return
    const detail = v as UTSJSONObject
    if (detail == null) return
    const valRaw = detail['value']
    if (valRaw == null) return
    if (typeof valRaw === 'boolean') draftEnabled = valRaw as boolean
    else if (typeof valRaw === 'number') draftEnabled = (valRaw as number) != 0
  } catch (_) {}
}

function onSave(): void {
  const pkgs: string[] = []
  if (!isDefault && draftAppsText.length > 0) {
    const lines = draftAppsText.split('\n')
    for (let i = 0; i < lines.length; i++) {
      const t = (lines[i] as string).trim()
      if (t.length > 0) pkgs.push(t)
    }
  }
  const tw: TimeWindow | null = draftTimeEnabled
    ? { start: pad2(draftStartHour) + ':00', end: pad2(draftEndHour) + ':00' }
    : null
  const out: PersistedEffectiveRule = {
    id: ruleId,
    actionId: isDefault ? '' : draftActionId,
    appPackages: pkgs,
    timeWindow: tw,
    timeThresholdMinutes: draftThreshold,
    triggerLevel: isDefault ? 'gentle' : draftLevel,
    categoryFilter: null,
    source: ruleSource,
    sourceHistoryId: ruleSourceHistoryId,
    expiresAt: ruleExpiresAt,
    enabled: draftEnabled,
    priority: isDefault ? 0 : 5,
    createdAt: ruleCreatedAt,
    updatedAt: Math.floor(Date.now() / 1000)
  }
  emit('save', out)
}

function onDelete(): void {
  if (isDefault) return
  emit('delete', ruleId)
}

watch((): boolean => props.visible, (v: boolean): void => {
  if (v) resetDraft()
})
</script>

<style scoped>
