}
.time-pill-active {
  background-color: #3498DB;
}
.time-pill-text {
  font-size: 13px;
  color: #2C3E50;
}
.time-pill-active .time-pill-text {
  color: #FFFFFF;
}
.time-inputs {
  flex-direction: row;
  justify-content: space-between;
  margin-top: 8px;
}
.time-input {
  flex-direction: row;
  align-items: center;
}
.time-input-label {
  font-size: 13px;
