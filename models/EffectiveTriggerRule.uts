export type TimeWindow = {
  start: string
  end: string
}

export type ScreenConditions = {
  appPackages: string[]
  includeHome: boolean
}

export type TriggerLevel = 'gentle' | 'strong' | 'forced'

export type EffectiveTriggerRule = {
  id: number
  actionId: string
  timeWindow: TimeWindow | null
  screenConditions: ScreenConditions | null
  timeThresholdMinutes: number
  categoryFilter: string | null
  source: 'local' | 'llm' | 'user' | 'system'
  enabled: boolean
  createdAt: number
}
