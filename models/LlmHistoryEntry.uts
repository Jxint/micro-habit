import { EffectiveTriggerRule } from './EffectiveTriggerRule'

export type LlmHistoryStage = 'pre' | 'post'

export type ParsedLlmResult = {
  adhocText?: string
  stateDescription?: string
  suggestedRule?: EffectiveTriggerRule
  reasoning?: string
  decision?: string
  targetRuleId?: number
  confidence?: number
  alternatives?: Array<any>
}

export type LlmHistoryEntry = {
  id: number
  stage: LlmHistoryStage
  contextJson: string
  aiRawResponse: string
  parsedResult: ParsedLlmResult
  adhocText: string | null
  suggestedRule: EffectiveTriggerRule | null
  reasoning: string | null
  decision: string | null
  targetRuleId: number | null
  userAccepted: number | null
  confidence: number
  createdAt: number
}
