<template>
  <view class="history-card">
    <view class="history-header" @tap="toggle">
      <text class="history-title">AI 历次判断</text>
      <text class="history-count">{{ entries.length }} 条</text>
      <text class="history-arrow">{{ expanded ? '▼' : '▶' }}</text>
    </view>
    <view v-if="expanded" class="history-list">
      <view v-if="entries.length < 1" class="history-empty">
        <text class="history-empty-text">暂无记录</text>
      </view>
      <view
        v-for="(entry, idx) in entries"
        :key="'h-' + idx"
        class="history-item"
      >
        <view class="history-item-header">
          <text class="history-stage" :class="entry.stage === 'pre' ? 'stage-pre' : 'stage-post'">
           💬 {{ entry.stage === 'pre' ? '触发时' : '复评时' }}
          </text>
          <text class="history-time">{{ formatTime(entry.createdAt) }}</text>
        </view>
        <text v-if="entry.adhocText != null && entry.adhocText.length > 0" class="history-adhoc">
          🤔 {{ entry.adhocText }}
        </text>
        <text v-if="entry.reasoning != null && entry.reasoning.length > 0" class="history-reasoning">
          {{ entry.reasoning }}
        </text>
        <view v-if="entry.suggestedRule != null" class="history-rule">
          <text class="history-rule-label">建议规则</text>
          <text class="history-rule-content">{{ formatRule(entry.suggestedRule) }}</text>
        </view>
      </view>
    </view>
  </view>
</template>

<script setup lang="uts">
import { LlmHistoryEntry } from '../models/LlmHistoryEntry'
import { EffectiveTriggerRule } from '../models/EffectiveTriggerRule'
import { getActionById } from '../constants/Actions'

const props = withDefaults(defineProps<{
  entries: LlmHistoryEntry[]
}>(), { entries: () => [] })

const expanded = ref<boolean>(false)

function toggle(): void { expanded.value = !expanded.value }

function formatTime(timestamp: number): string {
  const d = new Date(timestamp * 1000)
  const m = d.getMonth() + 1
  const day = d.getDate()
  const h = d.getHours().toString().padStart(2, '0')
  const min = d.getMinutes().toString().padStart(2, '0')
  return m + '/' + day + ' ' + h + ':' + min
}

function formatRule(r: EffectiveTriggerRule): string {
  const parts: string[] = []
  const a = getActionById(r.actionId)
  parts.push(a != null ? a.name : r.actionId)
  if (r.timeWindow != null) parts.push(r.timeWindow.start + '~' + r.timeWindow.end)
  if (r.timeThresholdMinutes > 0) parts.push('≥' + r.timeThresholdMinutes + 'min')
  return parts.join(' · ')
}
</script>

<style scoped>
.history-card { background-color: rgba(29, 25, 62, 0.82); background-image: linear-gradient(135deg, rgba(48, 42, 94, 0.92) 0%, rgba(84, 65, 124, 0.72) 56%, rgba(198, 141, 192, 0.18) 100%); border-width: 1px; border-color: rgba(219, 200, 237, 0.18); border-style: solid; margin: 12px 16px; border-radius: 24px; padding: 12px; }
.history-header { flex-direction: row; align-items: center; padding: 4px; }
.history-title { flex: 1; font-size: 14px; font-weight: bold; color: #FFFFFF; }
.history-count,
.history-arrow,
.history-time,
.history-empty-text,
.history-adhoc,
.history-reasoning,
.history-rule-label { color: rgba(255, 255, 255, 0.68); }
.history-count { font-size: 12px; margin-right: 8px; }
.history-arrow { font-size: 12px; }
.history-list { margin-top: 8px; }
.history-empty { padding: 16px; align-items: center; }
.history-empty-text { font-size: 12px; }
.history-item { padding: 8px 4px; border-bottom-width: 1px; border-bottom-color: rgba(219, 200, 237, 0.14); border-bottom-style: solid; flex-direction: column; }
.history-item-header { flex-direction: row; align-items: center; margin-bottom: 4px; }
.history-stage { font-size: 10px; font-weight: bold; padding: 3px 7px; border-radius: 8px; margin-right: 6px; }
.stage-pre { background-color: rgba(219, 200, 237, 0.18); color: #DBC8ED; }
.stage-post { background-color: rgba(194, 224, 238, 0.14); color: #C2E0EE; }
.history-time { font-size: 11px; }
.history-adhoc,
.history-reasoning { font-size: 12px; line-height: 18px; margin-bottom: 4px; }
.history-rule { background-color: rgba(255, 255, 255, 0.1); border-radius: 14px; padding: 8px 10px; margin-top: 4px; }
.history-rule-label { font-size: 10px; margin-bottom: 2px; }
.history-rule-content { font-size: 12px; color: #FFFFFF; font-weight: bold; }
</style>
