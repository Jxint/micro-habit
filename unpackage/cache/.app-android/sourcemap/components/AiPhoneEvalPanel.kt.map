.summary-row { flex-direction: row; align-items: center; justify-content: space-between; padding: 12px 16px; margin-bottom: 12px; background-color: rgba(255, 255, 255, 0.1); border-width: 1px; border-color: rgba(219, 200, 237, 0.14); border-style: solid; border-radius: 18px; }
.summary-num-block, .summary-stat { flex-direction: row; align-items: flex-end; }
.summary-num, .summary-num-sub, .summary-stat-num, .ai-block-title { color: #FFFFFF; font-weight: bold; }
.summary-num { font-size: 24px; }
.summary-num-sub { font-size: 16px; margin-left: 4px; }
.summary-stat-num { font-size: 18px; }
.summary-stat-label { font-size: 12px; margin-left: 4px; color: rgba(255, 255, 255, 0.7); }
.chart-block { flex-direction: column; padding: 8px 4px; margin-bottom: 12px; }
.stacked-bar { width: 100%; height: 16px; flex-direction: row; border-radius: 8px; overflow: hidden; background-color: rgba(255, 255, 255, 0.12); margin-bottom: 8px; }
.stacked-seg { height: 100%; }
.legend-row { flex-direction: row; align-items: center; margin-bottom: 6px; }
.legend-dot { width: 10px; height: 10px; border-radius: 5px; margin-right: 6px; }
.legend-label { flex: 1; font-size: 12px; color: rgba(255, 255, 255, 0.78); }
.legend-percent { font-size: 12px; font-weight: bold; color: #FFFFFF; margin-right: 4px; }
.legend-minutes { font-size: 11px; width: 32px; text-align: right; color: rgba(255, 255, 255, 0.62); }
.empty-block { padding: 30px 16px; align-items: center; margin-bottom: 12px; background-color: rgba(255, 255, 255, 0.08); border-radius: 18px; }
.empty-text { font-size: 13px; color: rgba(255, 255, 255, 0.78); }
.ai-block { padding: 14px 16px; background-color: rgba(255, 255, 255, 0.1); border-width: 1px; border-color: rgba(219, 200, 237, 0.14); border-style: solid; border-radius: 18px; flex-direction: column; }
.ai-block-header { flex-direction: row; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.ai-block-title { font-size: 14px; }
.ai-action-row { flex-direction: row; }
.ai-action-btn { padding: 5px 10px; background-color: rgba(255, 255, 255, 0.14); border-radius: 12px; margin-left: 6px; }
.ai-action-text { font-size: 11px; color: #DBC8ED; }
.ai-content { padding: 4px 0; }
.ai-text { font-size: 14px; line-height: 22px; color: #FFFFFF; }
.ai-placeholder { padding: 4px 0; }
.ai-placeholder-text { font-size: 12px; line-height: 18px; color: rgba(255, 255, 255, 0.62); }
.ai-loading { padding: 16px 0; align-items: center; }
.ai-loading-text { font-size: 12px; color: rgba(255, 255, 255, 0.78); }
.ai-btn { margin-top: 12px; padding: 11px 14px; background-color: #DBC8ED; border-radius: 16px; align-items: center; justify-content: center; }
.ai-btn-loading { background-color: rgba(255, 255, 255, 0.18); }
.ai-btn-text { font-size: 13px; color: #161A33; font-weight: bold; }
</style>
