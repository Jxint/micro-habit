<template>
  <view class="ai-panel">
    <view v-if="summaryAppCount > 0" class="summary-row">
      <view class="summary-num-block">
        <text class="summary-num">{{ hourTextStr }}</text>
        <text class="summary-num-sub">{{ minuteTextStr }}</text>
      </view>
      <view class="summary-stat">
        <text class="summary-stat-num">{{ appCountStr }}</text>
        <text class="summary-stat-label">个应用</text>
      </view>
    </view>

    <view v-if="segments.length > 0" class="chart-block">
      <view class="stacked-bar">
        <view
          v-for="(seg, si) in segments"
          :key="'sg-' + si"
          class="stacked-seg"
          :style="{
            flexGrow: seg.minutes > 0 ? seg.minutes : 0,
            backgroundColor: seg.color
          }"
        ></view>
      </view>
      <view
        v-for="(seg, si) in segments"
        :key="'lg-' + si"
        class="legend-row"
      >
        <view class="legend-dot" :style="{ backgroundColor: seg.color }"></view>
        <text class="legend-label">{{ seg.label }}</text>
        <text class="legend-percent">{{ seg.percent }}%</text>
        <text class="legend-minutes">{{ seg.minutes }}分</text>
      </view>
    </view>

    <view v-else class="empty-block">
      <text class="empty-text">今日暂无手机使用数据</text>
    </view>

    <view class="ai-block">
      <view class="ai-block-header">
        <text class="ai-block-title">AI 评价</text>
        <view v-if="aiText.length > 0" class="ai-action-row">
          <view class="ai-action-btn" @tap="onCopy">
            <text class="ai-action-text">复制</text>
          </view>
          <view class="ai-action-btn" @tap="onListen">
            <text class="ai-action-text">{{ listening ? '停止' : '朗读' }}</text>
          </view>
        </view>
      </view>
      <view v-if="aiLoading" class="ai-loading">
        <text class="ai-loading-text">AI 正在生成评价…</text>
      </view>
      <view v-else-if="aiText.length > 0" class="ai-content">
        <text class="ai-text" :selectable="true" :user-select="true">{{ aiText }}</text>
      </view>
      <view v-else class="ai-placeholder">
        <text class="ai-placeholder-text">点击下方按钮，AI 将根据今日使用情况生成评价</text>
      </view>
      <view class="ai-btn" :class="aiLoading ? 'ai-btn-loading' : ''" @tap="onAiTap">
        <text class="ai-btn-text">{{ aiLoading ? '生成中…' : aiText.length > 0 ? '重新生成' : '立即生成 AI 评价' }}</text>
      </view>
    </view>
  </view>
</template>

<script setup lang="uts">
import type { PieSegment } from '../services/PhoneUsageService'

const props = withDefaults(defineProps<{
  summaryHourText: string
  summaryMinuteText: string
  summaryAppCount: number
  segments: PieSegment[]
  aiText: string
  aiLoading: boolean
}>(), {
  summaryHourText: '0 小时',
  summaryMinuteText: '0 分钟',
  summaryAppCount: 0,
  segments: () => [],
  aiText: '',
  aiLoading: false
})

const emit = defineEmits<{
  (e: 'regenerate'): void
  (e: 'speak', text: string): void
  (e: 'stopSpeak'): void
}>()

let listening: boolean = false

const hourTextStr = computed<string>(() : string => props.summaryHourText)
const minuteTextStr = computed<string>(() : string => props.summaryMinuteText)
const appCountStr = computed<string>(() : string => '' + props.summaryAppCount)

function onAiTap(): void {
  if (props.aiLoading) return
  emit('regenerate')
}

function onCopy(): void {
  try {
    uni.setClipboardData({ data: props.aiText })
    uni.showToast({ title: '已复制', icon: 'success' })
  } catch (e) {
    console.warn('[AiPhoneEvalPanel] onCopy 异常: ' + JSON.stringify(e))
  }
}

function onListen(): void {
  if (listening) {
    listening = false
    emit('stopSpeak')
    return
  }
  if (props.aiText.length < 1) return
  listening = true
  emit('speak', props.aiText)
}
</script>

