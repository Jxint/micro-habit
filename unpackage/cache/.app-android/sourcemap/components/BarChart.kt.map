<template>
  <view class="chart-wrapper" :style="{ height: wrapperH + 'px' }">
    <view v-if="title.length > 0" class="chart-title">
      <text class="chart-title-text">{{ title }}</text>
    </view>
    <scroll-view class="chart-scroll" scroll-x="true" :show-scrollbar="false">
      <view class="chart-row" :style="{ width: rowW + 'px' }">
        <view
          v-for="(v, idx) in values"
          :key="idx"
          class="bar-col"
        >
          <view class="bar-value-row">
            <text v-if="v > 0" class="bar-value-text">{{ v }}</text>
          </view>
          <view class="bar-track">
            <view
              class="bar-fill"
              :style="{
                height: barHPercent(v) + '%',
                backgroundColor: v < 1 ? '#E8E8E8' : barColor
              }"
            ></view>
          </view>
          <view v-if="shouldShowLabel(idx)" class="bar-label-row">
            <text class="bar-label-text">{{ labels[idx] }}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</template>

<script setup lang="uts">
const props = withDefaults(defineProps<{
  labels: string[]
  values: number[]
  barColor: string
  title: string
  height: number
}>(), {
  labels: () => [],
  values: () => [],
  barColor: '#4CAF50',
  title: '',
  height: 240
})

const wrapperH = props.height
const rowW = 600

function getMaxVal(): number {
  let m = 0
  for (let i = 0; i < props.values.length; i++) {
    const v = props.values[i] as number
    if (v > m) m = v
  }
  if (m < 1) return 1
  return m
}

const maxVal = computed<number>(getMaxVal)

function barHPercent(v: number): number {
  if (v <= 0) return 0
  const m = maxVal.value
  if (m <= 0) return 0
  const r = (v / m) * 100
  return r < 2 ? 2 : r
}

function shouldShowLabel(idx: number): boolean {
  const len = props.labels.length
  if (len <= 24) return idx % 2 == 0
  return idx % 7 == 0
}
</script>

