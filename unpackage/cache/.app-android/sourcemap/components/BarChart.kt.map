  padding: 0 12px 4px 12px;
}
.chart-title-text {
  font-size: 13px;
  font-weight: bold;
  color: #2C3E50;
}
.chart-scroll {
  width: 100%;
  flex: 1;
}
.chart-row {
  flex-direction: row;
  align-items: flex-end;
  height: 100%;
}
.bar-col {
  width: 24px;
  flex-shrink: 0;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  margin: 0 1px;
}
.bar-value-row {
  height: 14px;
  align-items: center;
  justify-content: center;
}
.bar-value-text {
  font-size: 8px;
  color: #7F8C8D;
}
.bar-track {
  width: 100%;
  flex: 1;
  flex-direction: column;
  justify-content: flex-end;
  align-items: stretch;
}
.bar-fill {
  width: 70%;
  align-self: center;
  border-top-left-radius: 2px;
  border-top-right-radius: 2px;
  min-height: 1px;
}
.bar-label-row {
  height: 20px;
  align-items: center;
  justify-content: center;
}
.bar-label-text {
