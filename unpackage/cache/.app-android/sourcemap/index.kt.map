    __f__('warn','at services/CloudService.uts:84','[CloudService] callDaily empty raw')
    onFail()
  }, () => {
    __f__('warn','at services/CloudService.uts:87','[CloudService] callDaily failed, fallback to local')
    onFail()
  })
}

