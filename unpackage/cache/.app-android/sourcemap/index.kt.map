import * as LlmHistoryDao from '../database/LlmHistoryDao'

export function hasBeenRejected(targetRuleId: number, decision: string): boolean {
  if (targetRuleId < 1) return false
  try {
    return LlmHistoryDao.existsRejectedByRule(targetRuleId, decision)
  } catch (e) {
    __f__('warn','at services/LlmRejectTracker.uts:8','[LlmRejectTracker] hasBeenRejected 异常: ' + JSON.stringify(e))
    return false
  }
}

export function markAccepted(historyId: number): void {
  try {
    LlmHistoryDao.updateUserAccepted(historyId, 1)
  } catch (e) {
    __f__('warn','at services/LlmRejectTracker.uts:17','[LlmRejectTracker] markAccepted 失败: ' + JSON.stringify(e))
  }
}

export function markRejected(historyId: number): void {
  try {
    LlmHistoryDao.updateUserAccepted(historyId, 0)
  } catch (e) {
    __f__('warn','at services/LlmRejectTracker.uts:25','[LlmRejectTracker] markRejected 失败: ' + JSON.stringify(e))
  }
}
