import { callLlmEvaluate } from './CloudService'
import * as LlmHistoryDao from '../database/LlmHistoryDao'
import { EffectiveTriggerRule, TimeWindow, ScreenConditions, TriggerLevel } from '../models/EffectiveTriggerRule'
import { ParsedLlmResult, LlmHistoryStage } from '../models/LlmHistoryEntry'
import {
  PreTriggerContext,
  PostActionContext,
  getFallbackAdhoc
} from '../constants/LlmPrompts'
import { hasBeenRejected } from './LlmRejectTracker'

export type PreTriggerResult = {
  adhocText: string
  stateDescription: string
  fallback: boolean
}

export type PostActionResult = {
  suggestedRule: EffectiveTriggerRule | null
  decision: string
  reasoning: string
  confidence: number
  alternatives: string
  historyId: number
  fallback: boolean
}

let preContextCache: PreTriggerContext | null = null
let postContextCache: PostActionContext | null = null

export function setPreContext(ctx: PreTriggerContext): void {
  preContextCache = ctx
}

export function getPreContext(): PreTriggerContext | null {
  return preContextCache
}

export function clearPreContext(): void {
  preContextCache = null
}

export function setPostContext(ctx: PostActionContext): void {
  postContextCache = ctx
}

export function clearPostContext(): void {
  postContextCache = null
}

export function evaluatePre(
  onReady: (result: PreTriggerResult) => void,
  onFail: () => void
): void {
  __f__('log','at services/LlmTriggerFlow.uts:55','[LlmFlow] evaluatePre 开始')
  const ctx = preContextCache
  if (ctx == null) {
    __f__('warn','at services/LlmTriggerFlow.uts:58','[LlmFlow] evaluatePre: preContextCache 为空')
    onFail()
    return
  }
  const contextJson = JSON.stringify(ctx)
  __f__('log','at services/LlmTriggerFlow.uts:63','[LlmFlow] evaluatePre 上下文长度: ' + contextJson.length)
  try {
    __f__('log','at services/LlmTriggerFlow.uts:65','[LlmFlow] evaluatePre 调用 callLlmEvaluate pre')
    callLlmEvaluate(
      'pre',
      ctx,
      (raw: string): void => {
        __f__('log','at services/LlmTriggerFlow.uts:70','[LlmFlow] evaluatePre LLM 返回 raw 长度: ' + raw.length)
        try {
          const parsed = parsePreResponse(raw)
          __f__('log','at services/LlmTriggerFlow.uts:73','[LlmFlow] evaluatePre parsePreResult adhocText=' + (parsed.adhocText != null ? parsed.adhocText.substring(0, 30) : 'null'))
          const adhoc = parsed.adhocText != null ? parsed.adhocText : getFallbackAdhoc()
          const stateDesc = parsed.stateDescription != null ? parsed.stateDescription : '检测到需要休息'
          try {
            LlmHistoryDao.insertHistory('pre', contextJson, raw, parsed, adhoc, null, stateDesc)
          } catch (e) {
            __f__('warn','at services/LlmTriggerFlow.uts:79','[LlmTriggerFlow] 写 pre history 失败: ' + JSON.stringify(e))
          }
          const result: PreTriggerResult = {
            adhocText: adhoc,
            stateDescription: stateDesc,
            fallback: false
          }
          onReady(result)
        } catch (e) {
          __f__('warn','at services/LlmTriggerFlow.uts:88','[LlmTriggerFlow] pre parse 失败: ' + JSON.stringify(e))
          const fallback: PreTriggerResult = buildFallbackPre()
          try {
            LlmHistoryDao.insertHistory('pre', contextJson, raw, {}, fallback.adhocText, null, fallback.stateDescription)
          } catch (_) {}
          onReady(fallback)
        }
      },
      (): void => {
        __f__('warn','at services/LlmTriggerFlow.uts:97','[LlmFlow] evaluatePre LLM 请求失败，使用 fallback')
        const fallback: PreTriggerResult = buildFallbackPre()
        try {
          LlmHistoryDao.insertHistory('pre', contextJson, '', {}, fallback.adhocText, null, fallback.stateDescription)
        } catch (_) {}
        onReady(fallback)
      }
    )
  } catch (e) {
    __f__('warn','at services/LlmTriggerFlow.uts:106','[LlmTriggerFlow] pre 异常: ' + JSON.stringify(e))
    onFail()
  }
}

export function evaluatePost(
  actionId: string,
  actionName: string,
  actionCategory: string,
  durationMs: number,
  onReady: (result: PostActionResult) => void,
  onFail: () => void
): void {
  if (postContextCache == null) {
    onFail()
    return
  }
  const ctx = postContextCache
  if (ctx == null) {
    onFail()
    return
  }
  const enriched: PostActionContext = {
    actionId: actionId,
    actionName: actionName,
    actionCategory: actionCategory,
    durationMs: durationMs,
    originalContext: ctx.originalContext,
    todayCompletedCount: ctx.todayCompletedCount,
    guardMinutes: ctx.guardMinutes,
    todaySkipCount: ctx.todaySkipCount,
    recentActions: ctx.recentActions,
    appHistory: ctx.appHistory,
    currentRules: ctx.currentRules,
    userPreference: ctx.userPreference,
    lastWeekSameTime: ctx.lastWeekSameTime
  }
  const contextJson = JSON.stringify(enriched)
  try {
    callLlmEvaluate(
      'post',
      enriched,
      (raw: string): void => {
        try {
          const parsed = parsePostResponse(raw)
          const decision = parsed.decision != null ? parsed.decision : 'no_change'
          const rule = parsed.suggestedRule != null ? parsed.suggestedRule : null
          const reasoning = parsed.reasoning != null ? parsed.reasoning : ''
          const confidence = parsed.confidence != null ? parsed.confidence : 0
          const alternatives = parsed.alternatives != null ? JSON.stringify(parsed.alternatives) : ''
          let finalDecision = decision
          let finalRule = rule
          if (decision == 'modify_rule' || decision == 'delete_rule') {
            if (parsed.targetRuleId != null && parsed.targetRuleId > 0) {
              if (hasBeenRejected(parsed.targetRuleId, decision)) {
                finalDecision = 'no_change'
                finalRule = null
              }
            }
          }
          let historyId = 0
          try {
            historyId = LlmHistoryDao.insertHistory(
              'post',
              contextJson,
              raw,
              parsed,
              null,
              finalRule,
              reasoning,
              confidence,
              finalDecision,
              parsed.targetRuleId != null ? parsed.targetRuleId : null,
              null,
              alternatives
            )
          } catch (e) {
            __f__('warn','at services/LlmTriggerFlow.uts:183','[LlmTriggerFlow] 写 post history 失败: ' + JSON.stringify(e))
          }
          const result: PostActionResult = {
            suggestedRule: finalRule,
            decision: finalDecision,
            reasoning: reasoning,
            confidence: confidence,
            alternatives: alternatives,
            historyId: historyId,
            fallback: false
          }
          onReady(result)
        } catch (e) {
          __f__('warn','at services/LlmTriggerFlow.uts:196','[LlmTriggerFlow] post parse 失败: ' + JSON.stringify(e))
          let hid = 0
          try {
            hid = LlmHistoryDao.insertHistory('post', contextJson, raw, {}, null, null, '', 0, null, null, null, null)
          } catch (_) {}
          const result: PostActionResult = {
            suggestedRule: null,
            decision: 'no_change',
            reasoning: '',
            confidence: 0,
            alternatives: '',
            historyId: hid,
            fallback: true
          }
          onReady(result)
        }
      },
      (): void => {
        let hid = 0
        try {
          hid = LlmHistoryDao.insertHistory('post', contextJson, '', {}, null, null, '', 0, null, null, null, null)
        } catch (_) {}
        const result: PostActionResult = {
          suggestedRule: null,
          decision: 'no_change',
          reasoning: '',
          confidence: 0,
          alternatives: '',
          historyId: hid,
          fallback: true
        }
        onReady(result)
      }
    )
  } catch (e) {
    __f__('warn','at services/LlmTriggerFlow.uts:231','[LlmTriggerFlow] post 异常: ' + JSON.stringify(e))
    onFail()
  }
}

function buildFallbackPre(): PreTriggerResult {
  return {
    adhocText: getFallbackAdhoc(),
    stateDescription: '检测到需要休息',
    fallback: true
  }
}

function parsePreResponse(raw: string): ParsedLlmResult {
  const obj = parseJsonThreeLevels(raw)
  const result: ParsedLlmResult = {}
  if (obj == null) return result
  const adhoc = obj['adhocText']
  if (typeof adhoc === 'string' && (adhoc as string).length > 0) {
    result.adhocText = adhoc as string
  }
  const stateDesc = obj['stateDescription']
  if (typeof stateDesc === 'string' && (stateDesc as string).length > 0) {
    result.stateDescription = stateDesc as string
  }
  return result
}

function parsePostResponse(raw: string): ParsedLlmResult {
  const obj = parseJsonThreeLevels(raw)
  const result: ParsedLlmResult = {}
  if (obj == null) return result
  const decision = obj['decision']
  if (typeof decision === 'string' && (decision as string).length > 0) {
    result.decision = decision as string
  }
  const targetId = obj['targetRuleId']
  if (typeof targetId === 'number') {
    result.targetRuleId = targetId as number
  }
  const reasoning = obj['reasoning']
  if (typeof reasoning === 'string' && (reasoning as string).length > 0) {
    result.reasoning = reasoning as string
  }
  const conf = obj['confidence']
  if (typeof conf === 'number') {
    result.confidence = conf as number
  }
  const altArr = obj['alternatives']
  if (altArr != null) {
    try {
      const altStr = JSON.stringify(altArr)
      const alt = JSON.parse(altStr) as Array<any>
      if (alt != null) result.alternatives = alt
    } catch (_) {}
  }
  const rawRule = obj['suggestedRule']
  if (rawRule != null && typeof rawRule === 'object') {
    const rule = normalizeRule(rawRule as UTSJSONObject)
    if (rule != null) {
      result.suggestedRule = rule
    }
  }
  return result
}

function normalizeRule(raw: UTSJSONObject): EffectiveTriggerRule | null {
  const actionId = raw['actionId']
  if (typeof actionId !== 'string' || (actionId as string).length < 1) return null
  const actionIdStr = actionId as string
  let timeWindow: TimeWindow | null = null
  const tw = raw['timeWindow']
  if (tw != null && typeof tw === 'object') {
    const twObj = tw as UTSJSONObject
    const start = twObj['start']
    const end = twObj['end']
    if (typeof start === 'string' && typeof end === 'string') {
      const startStr = start as string
      const endStr = end as string
      if (startStr.length > 0 && endStr.length > 0) {
        const w: TimeWindow = { start: startStr, end: endStr }
        timeWindow = w
      }
    }
  }
  let screenConditions: ScreenConditions | null = null
  const sc = raw['screenConditions']
  if (sc != null && typeof sc === 'object') {
    const scObj = sc as UTSJSONObject
    const includeHomeRaw = scObj['includeHome']
    const includeHome = typeof includeHomeRaw === 'boolean' && (includeHomeRaw as boolean)
    const appPackagesRaw = scObj['appPackages']
    const pkgs: string[] = []
    if (appPackagesRaw != null) {
      try {
        const arrStr = JSON.stringify(appPackagesRaw)
        const arr = JSON.parse(arrStr) as Array<any>
        for (let i = 0; i < arr.length; i++) {
          const v = arr[i]
          if (typeof v === 'string') {
            const vs = v as string
            if (vs.length > 0) pkgs.push(vs)
          }
        }
      } catch (_) {}
    }
    const cond: ScreenConditions = { appPackages: pkgs, includeHome: includeHome }
    screenConditions = cond
  }
  let threshold: number = 60
  const thresholdRaw = raw['timeThresholdMinutes']
  if (typeof thresholdRaw === 'number') {
    threshold = (thresholdRaw as number).toInt()
  }
  const rule: EffectiveTriggerRule = {
    id: 0,
    actionId: actionIdStr,
    timeWindow: timeWindow,
    screenConditions: screenConditions,
    timeThresholdMinutes: threshold,
    source: 'llm',
    enabled: true,
    createdAt: Math.floor(Date.now() / 1000)
  }
  return rule
}

function parseJsonThreeLevels(raw: string): UTSJSONObject | null {
  let cleaned = raw
  if (cleaned.indexOf('```') >= 0) {
    const fenceStart = cleaned.indexOf('```')
    const afterFence = cleaned.substring(fenceStart + 3)
    const newlineIdx = afterFence.indexOf('\n')
    const afterLang = newlineIdx >= 0 ? afterFence.substring(newlineIdx + 1) : afterFence
    const endFence = afterLang.lastIndexOf('```')
    if (endFence > 0) {
      cleaned = afterLang.substring(0, endFence)
    } else {
      cleaned = afterLang
    }
  }
  try {
    return JSON.parse(cleaned) as UTSJSONObject
  } catch (_) {}
  try {
    const match = cleaned.match(/\{[\s\S]*\}/)
    if (match != null) {
      const m = match[0]
      if (m != null && m.length > 0) {
        return JSON.parse(m) as UTSJSONObject
      }
    }
  } catch (_) {}
  return null
}
