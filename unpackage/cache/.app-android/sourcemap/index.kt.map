import { getHomepageData } from './ScoreCalculator'
import { daysAgo } from '../utils/TimeUtils'
import { callWeekly } from './CloudService'
import { isNetworkAvailable } from '../utils/NetworkUtils'
import { WeeklyReport, WeeklyReportStats } from '../models/WeeklyReport'

export function generateWeeklyData(): WeeklyReportStats {
  let totalCompleted = 0
  let totalDurationSec = 0
  let totalPenetration = 0
  let totalGuardMinutes = 0
  let bestDay = ''
  let bestDayCount = -1
  let worstDay = ''
  let worstDayCount = 999999
  let daysWithData = 0

  for (let i = 6; i >= 0; i--) {
    const d = daysAgo(i)
    const data = getHomepageData(d)
    totalCompleted += data.todayCompletedCount
    totalDurationSec += data.guardCount * 60
    totalPenetration += data.penetration
    totalGuardMinutes += data.guardCount

    if (data.todayCompletedCount > 0) {
      daysWithData++
    }

    if (data.todayCompletedCount > bestDayCount) {
      bestDayCount = data.todayCompletedCount
      bestDay = d
    }

    if (data.todayCompletedCount < worstDayCount && data.todayCompletedCount >= 0) {
      worstDayCount = data.todayCompletedCount
      worstDay = d
    }
  }

  if (daysWithData === 0) {
    return {
      totalCompleted: 0,
      totalDurationSec: 0,
      avgPenetration: 0,
      avgGuardMinutes: 0,
      bestDay: '',
      bestDayCount: 0,
      worstDay: '',
      worstDayCount: 0
    }
  }

  return {
    totalCompleted: totalCompleted,
    totalDurationSec: totalDurationSec,
    avgPenetration: Math.round(totalPenetration / 7 * 100) / 100,
    avgGuardMinutes: Math.round(totalGuardMinutes / 7),
    bestDay: bestDay,
    bestDayCount: bestDayCount,
    worstDay: worstDay,
    worstDayCount: worstDayCount
  }
}

function cleanMarkdown(raw: string): string {
  if (raw == null) return ''
  let text = raw
  text = text.replace(/^```[\s\S]*?\n/, '')
  text = text.replace(/```$/, '')
  text = text.replace(/^#+\s*/gm, '')
  text = text.replace(/\*\*([^*]+)\*\*/g, '$1')
  text = text.replace(/\*([^*]+)\*/g, '$1')
  text = text.replace(/`([^`]+)`/g, '$1')
  text = text.replace(/[ \t]+\n/g, '\n')
  text = text.replace(/\n{3,}/g, '\n\n')
  return text.trim()
}

function buildLocalReport(stats: WeeklyReportStats): WeeklyReport {
  const hasData = stats.totalCompleted > 0
  if (hasData) {
    const body = '本周完成了 ' + stats.totalCompleted + ' 次微动作，累计守护 ' +
      Math.round(stats.totalDurationSec / 60) + ' 分钟。\n\n' +
      '你的平均每日守护时长为 ' + stats.avgGuardMinutes + ' 分钟，整体节奏稳定。' +
      '表现值得肯定。\n\n' +
      '下周可以尝试每天固定时间做一个微动作，把守护变成习惯。\n\n' +
      '目标：每天至少完成 3 次微动作。'
    return { bodyMarkdown: body, stats: stats }
  }
  const body = '本周暂无数据，从今天开始吧。\n\n' +
    '完成你的第一个微动作，开启健康守护之旅。\n\n' +
    '开启无障碍服务以自动提醒，设定你的健康偏好。\n\n' +
    '目标：开始你的第一个微动作。'
  return { bodyMarkdown: body, stats: stats }
}

export function generateWeeklyReport(onComplete: (report: WeeklyReport) => void): void {
  const stats = generateWeeklyData()

  if (!isNetworkAvailable()) {
    onComplete(buildLocalReport(stats))
    return
  }

  callWeekly(stats, (raw: string): void => {
    try {
      const cleaned = cleanMarkdown(raw)
      if (cleaned.length > 10) {
        onComplete({ bodyMarkdown: cleaned, stats: stats })
        return
      }
      __f__('warn','at services/WeeklyReportService.uts:113','[WeeklyReportService] LLM 返回内容过短, fallback')
    } catch (e) {
      __f__('warn','at services/WeeklyReportService.uts:115','[WeeklyReportService] 处理失败, fallback: ' + JSON.stringify(e))
    }
    onComplete(buildLocalReport(stats))
  }, () => {
    onComplete(buildLocalReport(stats))
  })
}
