let pendingActionId: string = ''
let pendingAdhocText: string = ''

export function setActionIdForNextPage(id: string): void {
  pendingActionId = id
}

export function takeActionId(): string {
  const id = pendingActionId
  pendingActionId = ''
  return id
}

export function setAdhocForNextPage(text: string): void {
  pendingAdhocText = text
}

export function takeAdhocText(): string {
  const t = pendingAdhocText
  pendingAdhocText = ''
  return t
}
