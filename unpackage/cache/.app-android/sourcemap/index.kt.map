export function callLlmEvaluate(
  stage: 'pre' | 'post',
  ctx: PreTriggerContext | PostActionContext,
  onOK: (raw: string) => void,
  onFail: () => void
): void {
  let userPrompt = ''
  try {
    if (stage === 'pre') {
      const pCtx = ctx as PreTriggerContext
      userPrompt = buildPreTriggerPrompt(pCtx)
      __f__('log','at services/CloudService.uts:128','[CloudService] callLlmEvaluate pre userPrompt len=' + userPrompt.length)
    } else {
      const pCtx = ctx as PostActionContext
      userPrompt = buildPostActionPrompt(pCtx)
      __f__('log','at services/CloudService.uts:132','[CloudService] callLlmEvaluate post userPrompt len=' + userPrompt.length)
    }
  } catch (e) {
    const msg = e != null ? ('' + e) : 'null'
    __f__('warn','at services/CloudService.uts:136','[CloudService] callLlmEvaluate prompt 构造失败: ' + msg)
    onFail()
    return
  }

  callMinimaxChat(SYSTEM_PROMPT_EVALUATE, userPrompt, 1500, (raw: string): void => {
    __f__('log','at services/CloudService.uts:142','[CloudService] callLlmEvaluate ' + stage + ' OK, rawLen=' + raw.length + ' preview=' + raw.substring(0, 80))
    onOK(raw)
  }, (): void => {
    __f__('warn','at services/CloudService.uts:145','[CloudService] callLlmEvaluate ' + stage + ' FAIL')
    onFail()
  })
}

function extractChatContent(data: any): string {
  try {
    const obj = data as UTSJSONObject
    if (obj == null) return ''
    const baseResp = obj.get('base_resp')
    if (baseResp != null) {
      const brObj = baseResp as UTSJSONObject
      const sc = brObj.get('status_code')
      if (sc != null && sc != 0) {
        const sm = brObj.get('status_msg')
        __f__('warn','at services/CloudService.uts:160','[CloudService] MiniMax 返回非 0 状态: ' + (sm != null ? '' + sm : ''))
        return ''
      }
    }
    const choicesRaw = obj.get('choices')
    if (choicesRaw == null) return ''
    const choices = choicesRaw as Array<UTSJSONObject>
    if (choices.length < 1) return ''
    const first = choices[0]
    if (first == null) return ''
    const message = first.get('message')
    if (message == null) return ''
    const msgObj = message as UTSJSONObject
    const content = msgObj.get('content')
    if (content != null) {
      const c = '' + content
      if (c.length > 0) return c
    }
    const rc = msgObj.get('reasoning_content')
    if (rc != null) {
      const r = '' + rc
      if (r.length > 0) return r
    }
  } catch (e) {
    __f__('warn','at services/CloudService.uts:184','[CloudService] extractChatContent exception: ' + JSON.stringify(e))
  }
  return ''
}

function extractFinishReason(data: UTSJSONObject): string {
  try {
    const choices = data.get('choices')
    if (choices == null) return ''
    const arr = choices as Array<UTSJSONObject>
    if (arr.length < 1) return ''
    const first = arr[0]
    if (first == null) return ''
    const fr = first.get('finish_reason')
    if (fr == null) return ''
    return '' + fr
  } catch (_) {
    return ''
  }
}

function parseJsonThreeLevels(raw: string): UTSJSONObject | null {
  try {
    const first = JSON.parse(raw)
    if (first != null) {
      if (typeof first === 'string') {
        try {
          const second = JSON.parse(first as string)
          if (second != null && typeof second === 'object') return second as UTSJSONObject
        } catch (_) {}
      } else if (typeof first === 'object') {
        return first as UTSJSONObject
      }
    }
  } catch (_) {}
  try {
    const match = raw.match(/\{[\s\S]*\}/)
    if (match != null) {
      const m = match[0]
      if (m != null && m.length > 0) {
        const second = JSON.parse(m)
        if (second != null && typeof second === 'object') return second as UTSJSONObject
      }
    }
  } catch (_) {}
  return null
}
