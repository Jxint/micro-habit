export function callMinimaxChat(systemPrompt: string, userPrompt: string, maxTokens: number, onOK: (raw: string) => void, onFail: () => void): void {
  if (MINIMAX_API_KEY === 'PLACEHOLDER_KEY') {
    __f__('warn','at services/CloudService.uts:21','[CloudService] MiniMax API key 未配置，走降级路径')
    onFail()
    return
  }

  const reqBody = {
    model: MINIMAX_CHAT_MODEL,
    messages: [
      { role: 'system', content: systemPrompt, name: 'MiniMax AI' },
      { role: 'user', content: userPrompt, name: '用户' }
    ],
    temperature: 0.7,
    max_completion_tokens: maxTokens,
    reasoning_effort: 'low'
  }

  try {
    uni.request({
      url: MINIMAX_BASE_URL + '/' + MINIMAX_CHAT_PATH,
      method: 'POST',
      header: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + MINIMAX_API_KEY
      },
      data: JSON.stringify(reqBody),
      timeout: 30000,
      success(res) {
        try {
          const data = res.data
          const statusCode = (data != null) ? (data as UTSJSONObject).get('base_resp') : null
          const finishReason = (data != null) ? extractFinishReason(data as UTSJSONObject) : ''
          __f__('log','at services/CloudService.uts:52','[CloudService] callMinimaxChat response, finishReason=' + finishReason)
          const content = extractChatContent(data != null ? data : '')
          if (content.length > 0) {
            __f__('log','at services/CloudService.uts:55','[CloudService] callMinimaxChat content OK, length=' + content.length)
            onOK(content)
          } else {
            __f__('warn','at services/CloudService.uts:58','[CloudService] callMinimaxChat empty content, raw data=' + JSON.stringify(data))
            onFail()
          }
        } catch (_) {
          onFail()
        }
      },
      fail(_err) {
        __f__('warn','at services/CloudService.uts:66','[CloudService] callMinimaxChat network fail: ' + JSON.stringify(_err))
        onFail()
      }
    })
  } catch (_) {
    onFail()
  }
}

