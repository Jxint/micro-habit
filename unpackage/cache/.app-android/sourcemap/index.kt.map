import { dbManager, type SqlRow } from './DatabaseManager'
import { DailySummary } from '../models/DailySummary'
import { daysAgo } from '../utils/TimeUtils'
import { DailyCount } from '../models/DailyCount'

export function insertOrUpdateSummary(summary: DailySummary): void {
  const existing = dbManager.queryOne('SELECT id FROM daily_summaries WHERE date = ?', [summary.date])
  if (existing != null) {
    const row: SqlRow = {
      columns: [
        'total_completed', 'total_skipped', 'total_duration_sec',
        'eye_score', 'posture_score', 'vitality_score',
        'penetration', 'phone_usage_min', 'guard_minutes', 'guard_count'
      ],
      values: [
        summary.total_completed, summary.total_skipped, summary.total_duration_sec,
        summary.eye_score, summary.posture_score, summary.vitality_score,
        summary.penetration, summary.phone_usage_min, summary.guard_minutes, summary.guard_count
      ]
    }
    dbManager.update('daily_summaries', row, 'date = ?', [summary.date])
  } else {
    const row: SqlRow = {
      columns: [
        'date', 'total_completed', 'total_skipped', 'total_duration_sec',
        'eye_score', 'posture_score', 'vitality_score',
        'penetration', 'phone_usage_min', 'guard_minutes', 'guard_count', 'created_at'
      ],
      values: [
        summary.date, summary.total_completed, summary.total_skipped, summary.total_duration_sec,
        summary.eye_score, summary.posture_score, summary.vitality_score,
        summary.penetration, summary.phone_usage_min, summary.guard_minutes, summary.guard_count, Math.floor(Date.now() / 1000)
      ]
    }
    dbManager.insert('daily_summaries', row)
  }
}

export function getRecent28Days(): DailyCount[] {
  const startDate = daysAgo(28)
  const rows = dbManager.query(
    'SELECT date, total_completed as count FROM daily_summaries WHERE date >= ? ORDER BY date ASC',
    [startDate]
  )
  const result: DailyCount[] = []
  for (let i = 0; i < rows.length; i++) {
    const row = rows[i]
    result.push({ date: row.get("date") as string, count: row.get("count") as number })
  }
  return result
}

export function getSummaryByDate(date: string): DailySummary | null {
  const row = dbManager.queryOne('SELECT * FROM daily_summaries WHERE date = ?', [date])
  return row != null ? mapRow(row) : null
}

function mapRow(row: Map<string, any>): DailySummary {
  return {
    id: row.get("id") as number,
    date: row.get("date") as string,
    total_completed: row.get("total_completed") as number,
    total_skipped: row.get("total_skipped") as number,
    total_duration_sec: row.get("total_duration_sec") as number,
    eye_score: row.get("eye_score") as number,
    posture_score: row.get("posture_score") as number,
    vitality_score: row.get("vitality_score") as number,
    penetration: row.get("penetration") as number,
    phone_usage_min: row.get("phone_usage_min") as number,
    guard_minutes: row.get("guard_minutes") as number,
    guard_count: row.get("guard_count") as number,
    created_at: row.get("created_at") as number
  }
}
