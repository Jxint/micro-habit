<template>
  <view class="page">
    <view class="page-bg">
      <image class="page-bg-img" src="/static/images/micro-habit-page-bg.png" mode="aspectFill"></image>
    </view>
    <scroll-view class="scroll-area" scroll-y="true">
      <view class="header-block">
        <text class="header-title">App 分类管理</text>
        <text class="header-desc">首次见到的 App 会由系统自动归类，你可在此手动调整。已锁定的分类 LLM 不会覆盖。</text>
      </view>

      <view class="filter-row">
        <view
          v-for="(cat, ci) in categories"
          :key="'cat-' + ci"
          class="filter-chip"
          :class="filterIdx === ci ? 'filter-chip-active' : ''"
          @tap="setFilter(ci)">
          <text class="filter-chip-text">{{ cat }}</text>
        </view>
      </view>

      <view v-if="visibleTags.length < 1" class="empty-block">
        <text class="empty-text">暂无数据</text>
        <text class="empty-hint">开启使用情况权限后，系统会自动记录你常用的 App</text>
      </view>

      <view v-else class="tag-list">
        <view v-for="(tag, ti) in visibleTags" :key="'t-' + ti" class="tag-card">
          <view class="tag-card-left">
            <text class="tag-label">{{ tag.appLabel }}</text>
            <text class="tag-pkg">{{ tag.packageName }}</text>
            <view class="tag-source-row">
              <text class="tag-source" :class="getSourceClass(tag.tagSource)">{{ getSourceText(tag.tagSource) }}</text>
              <text v-if="tag.totalUses > 0" class="tag-uses">使用 {{ tag.totalUses }} 次</text>
            </view>
          </view>
          <view class="tag-card-right">
              <picker mode="selector" :range="categories" :value="getCategoryIdx(tag.category)" @change="(e: UTSJSONObject) => onCategoryChange(tag.packageName, e)">
              <view class="cat-picker">
                <text class="cat-picker-text">{{ tag.category }}</text>
                <text class="cat-picker-arrow">▾</text>
              </view>
            </picker>
            <view class="lock-row" @tap="toggleLock(tag.packageName, !tag.isUserLocked)">
              <text class="lock-text" :class="tag.isUserLocked ? 'lock-text-on' : ''">{{ tag.isUserLocked ? '🔒 已锁定' : '🔓 未锁' }}</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</template>

<script setup lang="uts">
import * as AppTagsDao from '../../../database/AppTagsDao'
import { AppTag, AppCategory } from '../../../models/AppTag'
import { manualSetCategory } from '../../../services/AppCategoryService'

const categories: string[] = ['social', 'video', 'game', 'work', 'study', 'reading', 'other']
const filterIdx = ref<number>(-1)
const allTags = ref<AppTag[]>([])

const visibleTags = computed<AppTag[]>(() : AppTag[] => {
  const list = allTags.value
  if (filterIdx.value < 0 || filterIdx.value >= categories.length) return list
  const targetCat = categories[filterIdx.value] as string
  const result: AppTag[] = []
  for (let i = 0; i < list.length; i++) {
    const t = list[i]
    if (t.category == targetCat) result.push(t)
  }
  return result
})

function setFilter(idx: number): void {
  filterIdx.value = idx
}

function getCategoryIdx(cat: string): number {
  for (let i = 0; i < categories.length; i++) {
    if (categories[i] == cat) return i
  }
  return categories.length - 1
}

function getSourceText(s: string): string {
  if (s == 'llm') return 'LLM 分类'
  if (s == 'user') return '手动设置'
  return '待分类'
}

function getSourceClass(s: string): string {
  if (s == 'llm') return 'tag-source-llm'
  if (s == 'user') return 'tag-source-user'
  return 'tag-source-pending'
}

function refresh(): void {
  try {
    allTags.value = AppTagsDao.listAll()
  } catch (err) {
    console.warn('[app-categories] refresh 异常: ' + JSON.stringify(err))
    allTags.value = []
  }
}

function onCategoryChange(pkg: string, e: UTSJSONObject): void {
  try {
    if (e == null) return
    const detail = e['detail']
    if (detail == null) return
    const detailObj = detail as UTSJSONObject
    if (detailObj == null) return
    const val = detailObj['value']
    if (typeof val !== 'number') return
    const idx: number = (val as number).toInt()
    if (idx < 0 || idx >= categories.length) return
    const cat = categories[idx] as AppCategory
    manualSetCategory(pkg, cat)
    refresh()
    uni.showToast({ title: '已更新', icon: 'none' })
  } catch (err) {
    console.warn('[app-categories] onCategoryChange 异常: ' + JSON.stringify(err))
  }
}

function toggleLock(pkg: string, locked: boolean): void {
  try {
    AppTagsDao.setUserLocked(pkg, locked)
    refresh()
  } catch (err) {
    console.warn('[app-categories] toggleLock 异常: ' + JSON.stringify(err))
  }
}

onPageShow(() => {
  refresh()
})

function onBack(): void {
  uni.navigateBack()
}
</script>

