<template>
  <view class="page">
    <view class="page-bg">
      <image class="page-bg-img" src="/static/images/micro-habit-page-bg.png" mode="aspectFill"></image>
    </view>
    <view class="bg-glow glow-purple"></view>
    <view class="bg-glow glow-blue"></view>
    <view class="bg-glow glow-pink"></view>
    <view class="sky-star star-a"></view>
    <view class="sky-star star-b"></view>
    <view class="sky-star star-c"></view>
    <view class="sky-star star-d"></view>
    <view class="sky-star star-e"></view>
    <view class="sky-star star-f"></view>
    <view class="sky-star star-g"></view>
    <view class="sky-star star-h"></view>
    <view class="sky-star star-i"></view>
    <view class="sky-star star-j"></view>
    <view class="sky-star star-k"></view>
    <view class="sky-star star-l"></view>
    <view class="back-button" @tap="goBack">
      <text class="back-icon">‹</text>
    </view>
    <view class="action-container">
      <text class="ritual-label">{{ ritualLabel }}</text>
      <text class="action-title">{{ actionName }}</text>
      <text class="action-subtitle">{{ executeIntro }}</text>

      <view class="lottie-stage" :class="lottiePlaying ? 'lottie-stage-playing' : 'lottie-stage-paused'">
        <view class="lottie-glow">
          <view class="lottie-orbit"></view>
          <view class="icon-display">
            <image class="action-icon-img" :src="actionIconSrc" mode="aspectFit"></image>
          </view>
        </view>
        <text class="lottie-placeholder">{{ lottieStateText }}</text>
        <view class="lottie-controls">
          <view class="lottie-chip" @tap="toggleLottiePlaying">
            <text class="lottie-chip-text">{{ lottiePlaying ? '暂停' : '播放' }}</text>
          </view>
          <view class="lottie-chip" :class="lottieLoop ? 'lottie-chip-active' : ''" @tap="toggleLottieLoop">
            <text class="lottie-chip-text" :class="lottieLoop ? 'lottie-chip-text-active' : ''">{{ lottieLoop ? '循环中' : '循环' }}</text>
          </view>
        </view>
      </view>

      <text v-if="!showCountdown" class="tts-text">{{ actionTtsText }}</text>
      <text v-if="showCountdown" class="tts-text execute-guide">{{ executeGuide }}</text>

      <view v-if="showCountdown">
        <CountdownBar :total="actionDuration" :remaining="remainingMs" />
      </view>

      <view v-if="showButtons" class="button-group">
        <button class="action-btn action-primary" @tap="handleAgree">好啊</button>
        <button class="action-btn action-secondary" @tap="handleSelfReported">我做过了</button>
        <button class="action-btn action-ghost" @tap="handleBusy">现在忙，晚点提醒我</button>
      </view>

      <view v-if="showSkip" class="button-group">
        <button class="action-btn action-ghost" @tap="handleSkipDuringExec">跳过这次</button>
      </view>
    </view>

    <EncourageToast :visible="showEncourage" :text="encourageText" />

    <FeedbackDialog :visible="showFeedback" @confirm="onFeedbackConfirm" @cancel="onFeedbackCancel" />

  </view>
</template>

<script setup lang="uts">
import CountdownBar from '../../components/CountdownBar.uvue'
import EncourageToast from '../../components/EncourageToast.uvue'
import FeedbackDialog from '../../components/FeedbackDialog.uvue'
import { MicroAction } from '../../models/MicroAction'
import { getActionById } from '../../constants/Actions'
import { getRandomEncourage } from '../../constants/EncourageTexts'
import { insertManualActionLog } from '../../database/ActionLogDao'
import { onCompleted, onConsecutiveSkip } from '../../services/RuleEngine'
import { takeActionId } from '../../utils/NavigationHelper'
import { shortVibrate } from '../../utils/VibrateUtils'
import { getExecuteGuide, getExecuteIntro } from '../../constants/MicroPlanetCopy'

const actionId = ref<string>('')
const action = ref<MicroAction | null>(null)
const isExecuting = ref<boolean>(false)
const isCompleted = ref<boolean>(false)
const showEncourage = ref<boolean>(false)
const encourageText = ref<string>('')
const showFeedback = ref<boolean>(false)
const remainingMs = ref<number>(0)
const lottiePlaying = ref<boolean>(true)
const lottieLoop = ref<boolean>(true)
let countdownTimerId: number | null = null

const showButtons = computed<boolean>((): boolean => {
  const a = action.value
  const exec = isExecuting.value
  const done = isCompleted.value
  return a != null && exec === false && done === false
})

const showCountdown = computed<boolean>((): boolean => {
  return isExecuting.value === true
})

const showSkip = computed<boolean>((): boolean => {
  const exec = isExecuting.value
  const done = isCompleted.value
  return exec === true && done === false
})

const actionName = computed<string>((): string => {
  const a = action.value
  return a != null ? a.name : '未找到动作'
})

const actionTtsText = computed<string>((): string => {
  const a = action.value
  return a != null ? a.ttsText : ''
})

const actionDuration = computed<number>((): number => {
  const a = action.value
  return a != null ? a.defaultDurationMs : 0
})

const actionIconSrc = computed<string>((): string => {
  const a = action.value
  return a != null ? a.iconPath : '/static/icons/eye_blink.png'
})

const executeIntro = computed<string>((): string => getExecuteIntro(actionId.value))
const executeGuide = computed<string>((): string => getExecuteGuide(actionId.value))
const ritualLabel = computed<string>((): string => isExecuting.value ? '正在点亮小星球' : '10 秒健康仪式')
function getActionCueText(id: string): string {
  if (id === 'eye_blink') return '轻闭双眼 2 秒后睁开，重复眨眼，让眼表重新湿润'
  if (id === 'eye_rotate') return '眼球缓慢画圈，顺时针一圈后再逆时针一圈'
  if (id === 'neck_rotate') return '肩膀放松，头部慢慢转向一侧，停 3 秒后回正'
  if (id === 'shoulder_roll') return '双肩向上提起，再向后画圈放下，保持动作缓慢'
  if (id === 'neck_stretch') return '坐直身体，轻轻侧屈头颈，感受肩颈外侧被拉长'
  if (id === 'core_tighten') return '收紧腹部和骨盆底，保持自然呼吸，不要憋气'
  if (id === 'heel_raise') return '双脚踩稳，缓慢踮起脚跟，再控制速度落回地面'
  if (id === 'deep_breath') return '鼻吸 4 秒让腹部鼓起，口呼 6 秒把气息慢慢送出'
  if (id === 'far_gaze') return '看向 6 米外的固定目标，放松眉心和眼周肌肉'
  return '跟随节奏完成这个微动作，保持放松、缓慢和可控'
}
const lottieStateText = computed<string>((): string => lottiePlaying.value ? getActionCueText(actionId.value) : '动作已暂停，准备好后继续跟着节奏完成')

/* ---------- leaf functions (no deps) ---------- */

function toggleLottiePlaying(): void {
  lottiePlaying.value = !lottiePlaying.value
}

function toggleLottieLoop(): void {
  lottieLoop.value = !lottieLoop.value
}

function goBack(): void {
  uni.navigateBack({})
}

function getActionIdFromOption(source: any): string {
  if (source == null) return ''
  try {
    const obj = source as UTSJSONObject
    if (obj == null) return ''
    const raw = obj['actionId']
    if (raw == null) return ''
    const str = raw as string
    return str
  } catch (_) {
    return ''
  }
}

function clearCountdown(): void {
  const tid = countdownTimerId
  if (tid != null) {
    clearInterval(tid)
    countdownTimerId = null
  }
}

function emitLlmActionCompleted(a: MicroAction, durationMs: number, result: string): void {
  try {
    uni.$emit('llmActionCompleted', {
      actionId: a.id,
      actionName: a.name,
      actionCategory: a.category,
      durationMs: durationMs,
      result: result
    })
  } catch (e) {
    console.warn('[execute] emitLlmActionCompleted 失败: ' + JSON.stringify(e))
  }
}

function recordAction(result: string, skipReason: string = ''): void {
  console.log('[execute] recordAction enter, result=' + result)
  const a = action.value
  if (a == null) {
    console.log('[execute] recordAction SKIP: action.value is null')
    return
  }
  const nowMs = Date.now()
  const dur = result === 'completed' ? a.defaultDurationMs : Math.floor(a.defaultDurationMs - remainingMs.value)
  const insertId = insertManualActionLog(
    a.id,
    a.category,
    result,
    skipReason.length > 0 ? skipReason : null,
    dur,
    a.defaultDurationMs,
    nowMs - 30000,
    nowMs,
    Math.floor(nowMs / 1000)
  )
  console.log('[execute] insertActionLog 返回 id=' + insertId)
  emitLlmActionCompleted(a, dur, result)
}

/* ---------- mid-layer functions ---------- */

function showEncourageNow(): void {
  const a = action.value
  const cat = a != null ? a.category : ''
  encourageText.value = getRandomEncourage(cat)
  showEncourage.value = true
  isCompleted.value = true
  setTimeout((): void => {
    showEncourage.value = false
    uni.navigateBack({})
  }, 1500)
}

function startCountdown(): void {
  const interval = 100
  console.log('[execute] startCountdown total=' + remainingMs.value + 'ms')
  countdownTimerId = setInterval((): void => {
    remainingMs.value -= interval
    if (remainingMs.value <= 0) {
      remainingMs.value = 0
      clearCountdown()
      recordAction('completed')
      const a = action.value
      onCompleted(a != null ? a.category : '')
      showEncourageNow()
    }
  }, interval)
}

function handleAgree(): void {
  console.log('[execute] handleAgree')
  const a = action.value
  if (a == null) {
    uni.showToast({ title: '未找到动作', icon: 'none' })
    return
  }
  isExecuting.value = true
  remainingMs.value = a.defaultDurationMs
  console.log('[execute] countdown start, ms=' + a.defaultDurationMs)
  startCountdown()
  shortVibrate(1)
}

function handleSelfReported(): void {
  recordAction('self_reported')
  showEncourageNow()
}

function handleBusy(): void {
  recordAction('skipped', 'busy')
  setTimeout((): void => { uni.navigateBack({}) }, 300)
}

function handleSkipDuringExec(): void {
  clearCountdown()
  showFeedback.value = true
}

function onFeedbackConfirm(reason: string): void {
  showFeedback.value = false
  recordAction('skipped', reason)
  const a = action.value
  onConsecutiveSkip(a != null ? a.category : '')
  showEncourageNow()
}

function onFeedbackCancel(): void {
  showFeedback.value = false
  isExecuting.value = false
  uni.navigateBack({})
}

/* ---------- lifecycle hooks (must be LAST) ---------- */

onLoad((option) => {
  console.log('[execute] onLoad begin')
  let aid = takeActionId()
  console.log('[execute] from helper aid=' + aid)
  if (aid.length < 1) {
    aid = getActionIdFromOption(option)
    console.log('[execute] from option aid=' + aid)
  }
  actionId.value = aid
  if (aid.length > 0) {
    const found = getActionById(aid)
    action.value = found
    console.log('[execute] found action=' + (found != null ? found.name : 'null'))
  } else {
    console.log('[execute] no actionId')
  }
})

onUnload((): void => {
  clearCountdown()
})
</script>

<style scoped>
.page {
  flex: 1;
  background-color: #162038;
  position: relative;
  overflow: hidden;
}
.page-bg { position: absolute; left: 0; top: 0; width: 100%; height: 100%; z-index: 0; }
.page-bg-img { width: 100%; height: 100%; }
.scroll-area {
  flex: 1;
  position: relative;
  z-index: 1;
}
.bg-glow {
  position: absolute;
  border-radius: 999px;
  z-index: 0;
}
.glow-purple {
  width: 210px;
  height: 210px;
  left: -82px;
  top: -54px;
  background-color: #776B97;
  opacity: 0.5;
}
.glow-blue {
  width: 168px;
  height: 168px;
  right: -60px;
  top: 104px;
  background-color: #C2E0EE;
  opacity: 0.24;
}
.glow-pink {
  width: 178px;
  height: 178px;
  left: 42px;
  bottom: 88px;
  background-color: #C68DC0;
  opacity: 0.18;
}
.sky-star {
  position: absolute;
  width: 3px;
  height: 3px;
  border-radius: 2px;
  background-color: rgba(255, 255, 255, 0.74);
  z-index: 0;
}
.star-a { left: 36px; top: 88px; }
.star-b { left: 118px; top: 144px; width: 4px; height: 4px; border-radius: 2px; }
.star-c { right: 52px; top: 116px; }
.star-d { right: 26px; top: 310px; width: 5px; height: 5px; border-radius: 3px; }
.star-e { left: 54px; top: 520px; }
.star-f { right: 86px; top: 420px; width: 4px; height: 4px; border-radius: 2px; }
.star-g { left: 138px; top: 610px; }
.star-h { right: 36px; top: 720px; width: 4px; height: 4px; border-radius: 2px; }
.star-i { left: 76px; top: 214px; width: 2px; height: 2px; border-radius: 1px; }
.star-j { right: 148px; top: 276px; width: 3px; height: 3px; border-radius: 2px; }
.star-k { left: 178px; top: 392px; width: 2px; height: 2px; border-radius: 1px; }
.star-l { right: 64px; top: 560px; width: 3px; height: 3px; border-radius: 2px; }

.page { justify-content: flex-start; align-items: center; padding-top: 70px; }
.back-button { position: absolute; left: 18px; top: 28px; width: 38px; height: 38px; border-radius: 19px; background-color: rgba(255, 255, 255, 0.12); border-width: 1px; border-color: rgba(219, 200, 237, 0.16); border-style: solid; align-items: center; justify-content: center; z-index: 2; }
.back-icon { color: #FFFFFF; font-size: 30px; line-height: 34px; font-weight: bold; }
.action-container { width: 88%; background-color: rgba(29, 25, 62, 0.82); background-image: linear-gradient(135deg, rgba(48, 42, 94, 0.92) 0%, rgba(84, 65, 124, 0.72) 56%, rgba(198, 141, 192, 0.18) 100%); border-width: 1px; border-color: rgba(219, 200, 237, 0.18); border-style: solid; border-radius: 28px; padding: 26px 22px 22px 22px; box-shadow: 0 18px 42px rgba(5, 6, 20, 0.34); flex-direction: column; align-items: center; z-index: 1; }
.ritual-label { font-size: 12px; color: #DBC8ED; font-weight: bold; margin-bottom: 8px; }
.action-title { font-size: 28px; font-weight: bold; color: #FFFFFF; margin-bottom: 8px; text-align: center; }
.action-subtitle,
.tts-text,
.lottie-placeholder { color: rgba(255, 255, 255, 0.72); }
.action-subtitle { font-size: 14px; text-align: center; line-height: 20px; margin-bottom: 18px; padding: 0 10px; }
.lottie-stage { width: 100%; min-height: 196px; border-radius: 30px; background-color: rgba(255, 255, 255, 0.1); background-image: linear-gradient(135deg, rgba(79, 88, 125, 0.28) 0%, rgba(219, 200, 237, 0.12) 100%); align-items: center; justify-content: center; padding: 18px 14px; margin-bottom: 18px; border-width: 1px; border-color: rgba(219, 200, 237, 0.16); border-style: solid; }
.lottie-stage-playing { box-shadow: 0 14px 34px rgba(5, 6, 20, 0.24); }
.lottie-stage-paused { opacity: 0.86; }
.lottie-glow { width: 128px; height: 128px; border-radius: 64px; align-items: center; justify-content: center; background-color: rgba(219, 200, 237, 0.16); margin-bottom: 10px; }
.lottie-orbit { position: absolute; width: 122px; height: 48px; border-radius: 61px; border-width: 2px; border-color: rgba(219, 200, 237, 0.38); border-style: solid; }
.icon-display { width: 90px; height: 90px; border-radius: 45px; justify-content: center; align-items: center; background-color: rgba(219, 200, 237, 0.18); }
.action-icon-img { width: 78px; height: 78px; }
.lottie-placeholder { font-size: 11px; text-align: center; }
.lottie-controls { flex-direction: row; margin-top: 10px; }
.lottie-chip { padding: 6px 12px; border-radius: 15px; background-color: rgba(255, 255, 255, 0.1); margin: 0 4px; }
.lottie-chip-active { background-color: #DBC8ED; }
.lottie-chip-text { font-size: 11px; color: #DBC8ED; }
.lottie-chip-text-active { color: #161A33; }
.tts-text { font-size: 14px; line-height: 21px; text-align: center; margin-bottom: 18px; padding: 0 10px; }
.execute-guide { color: rgba(255, 255, 255, 0.86); }
.button-group { width: 100%; flex-direction: column; margin-top: 14px; }
.action-btn { width: 100%; padding: 14px; border-radius: 20px; font-size: 15px; text-align: center; margin-bottom: 10px; border-width: 1px; border-style: solid; }
.action-primary { background-color: #DBC8ED; color: #161A33; border-color: rgba(255, 255, 255, 0.16); font-weight: bold; }
.action-secondary { background-color: rgba(219, 200, 237, 0.16); color: rgba(255, 255, 255, 0.78); border-color: rgba(219, 200, 237, 0.16); }
.action-ghost { background-color: rgba(255, 255, 255, 0.08); color: rgba(255, 255, 255, 0.72); border-color: rgba(219, 200, 237, 0.16); }
.dialog-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; justify-content: center; align-items: center; background-color: rgba(0, 0, 0, 0.4); z-index: 999; }
.dialog-content { width: 280px; background-color: rgba(29, 25, 62, 0.94); border-radius: 24px; padding: 20px; flex-direction: column; border-width: 1px; border-color: rgba(219, 200, 237, 0.18); border-style: solid; }
.dialog-title { font-size: 17px; font-weight: bold; color: #FFFFFF; text-align: center; margin-bottom: 12px; }
.dialog-body-text { font-size: 14px; color: rgba(255, 255, 255, 0.72); line-height: 20px; text-align: center; margin-bottom: 16px; }
.dialog-actions { flex-direction: row; justify-content: space-between; }
.cancel-btn,
.confirm-btn { flex: 1; padding: 10px; border-radius: 14px; font-size: 14px; text-align: center; border-width: 0; }
.cancel-btn { margin-right: 8px; background-color: rgba(255, 255, 255, 0.1); color: rgba(255, 255, 255, 0.72); }
.confirm-btn { margin-left: 8px; background-color: #DBC8ED; color: #161A33; }
</style>
