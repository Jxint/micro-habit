import { existsRejectedByRule, updateUserAccepted } from '../database/LlmHistoryDao'

export function hasBeenRejected(targetRuleId: number, decision: string): boolean {
  if (targetRuleId < 1) return false
  try {
    return existsRejectedByRule(targetRuleId, decision)
  } catch (e) {
    console.warn('[LlmRejectTracker] hasBeenRejected 异常: ' + JSON.stringify(e))
    return false
  }
}

export function markAccepted(historyId: number): void {
  try {
    updateUserAccepted(historyId, 1)
  } catch (e) {
    console.warn('[LlmRejectTracker] markAccepted 失败: ' + JSON.stringify(e))
  }
}

export function markRejected(historyId: number): void {
  try {
    updateUserAccepted(historyId, 0)
  } catch (e) {
    console.warn('[LlmRejectTracker] markRejected 失败: ' + JSON.stringify(e))
  }
}
