import { getTodayAppBreakdown, getTop5Apps, getTodayTotalUsageSeconds, type AppUsageItem } from '../database/AppUsageDao'
import { queryUsageStatsOnce } from '../uni_modules/uts-usage-stats/utssdk/app-android/index'
import { today, currentHour } from '../utils/TimeUtils'
import { callMinimaxChat } from './CloudService'
import { countCompletedToday } from '../database/ActionLogDao'
import {
  SYSTEM_PROMPT_PHONE_USAGE,
  buildPhoneUsageEvalPrompt,
  getFallbackPhoneUsageEval,
  type PhoneUsageEvalInput,
  type TopAppEntry
} from '../constants/PhoneUsagePrompts'

export type PhoneUsageSummary = {
  totalMinutes: number
  totalSeconds: number
  hourText: string
  minuteText: string
  appCount: number
}

export type PieSegment = {
  pkg: string
  label: string
  minutes: number
  percent: number
  color: string
  startAngle: number
  endAngle: number
}

const PALETTE: string[] = [
  '#3498DB',
  '#2ECC71',
  '#9B59B6',
  '#E67E22',
  '#E74C3C',
  '#1ABC9C',
  '#F1C40F',
  '#34495E',
  '#16A085',
  '#D35400'
]

export function getTodayPhoneUsageSummary(): PhoneUsageSummary {
  const totalSeconds = getTodayTotalUsageSeconds()
  const minutes = Math.floor(totalSeconds / 60)
  const hours = Math.floor(minutes / 60)
  const remainMin = minutes % 60
  const breakdown = getTodayAppBreakdown()
  return {
    totalMinutes: minutes,
    totalSeconds: totalSeconds,
    hourText: hours + ' 小时',
    minuteText: remainMin + ' 分钟',
    appCount: breakdown.length
  }
}

export function getTodayPieSegments(): PieSegment[] {
  const all = getTodayAppBreakdown()
  let sumSec = 0
  for (let i = 0; i < all.length; i++) {
    sumSec += all[i].foregroundSec
  }
  if (sumSec < 1) return []
  const segments: PieSegment[] = []
  let start = 0
  const cap = all.length > 10 ? 10 : all.length
  for (let i = 0; i < cap; i++) {
    const item = all[i]
    const pct = (item.foregroundSec / sumSec) * 100
    const end = start + pct
    const color: string = i < PALETTE.length ? (PALETTE[i] as string) : '#BDC3C7'
    const seg: PieSegment = {
      pkg: item.packageName,
      label: item.appLabel.length > 0 ? item.appLabel : item.packageName,
      minutes: item.minutes,
      percent: Math.round(pct * 10) / 10,
      color: color,
      startAngle: start,
      endAngle: end
    }
    segments.push(seg)
    start = end
  }
  if (all.length > cap) {
    let othersMin = 0
    for (let i = cap; i < all.length; i++) {
      othersMin += all[i].minutes
    }
    const pct = 100 - start
    const seg: PieSegment = {
      pkg: '__others__',
      label: '其他',
      minutes: othersMin,
      percent: Math.round(pct * 10) / 10,
      color: '#BDC3C7',
      startAngle: start,
      endAngle: 100
    }
    segments.push(seg)
  }
  return segments
}

export function getTop5PhoneApps(): AppUsageItem[] {
  return getTop5Apps()
}

const LLM_RESERVED_NOTE = 'LLM 接口待配置'

export function aiEvaluateTodayUsage(onComplete: (text: string) => void): void {
  let summary: PhoneUsageSummary
  try {
    summary = getTodayPhoneUsageSummary()
  } catch (_) {
    summary = { totalMinutes: 0, totalSeconds: 0, hourText: '0 小时', minuteText: '0 分钟', appCount: 0 }
  }
  if (summary.totalSeconds < 1) {
    try {
      const sys = getPhoneUsageFromSystem()
      if (sys != null && sys.summary.totalSeconds > 0) {
        summary = sys.summary
      }
    } catch (_) {}
  }

  let topApps: AppUsageItem[] = []
  try { topApps = getTop5Apps() } catch (_) { topApps = [] }
  const topDtos: TopAppEntry[] = []
  for (let i = 0; i < topApps.length; i++) {
    const a = topApps[i]
    if (a == null) continue
    topDtos.push({
      packageName: a.packageName,
      appLabel: a.appLabel.length > 0 ? a.appLabel : a.packageName,
      totalSeconds: a.foregroundSec
    })
  }

  let guardCount = 0
  try { guardCount = countCompletedToday() } catch (_) { guardCount = 0 }

  const hourNow = currentHour()
  const isNight = hourNow >= 22 || hourNow < 7
  const isWorkHour = hourNow >= 9 && hourNow < 18

  const input: PhoneUsageEvalInput = {
    totalMinutes: summary.totalMinutes,
    totalSeconds: summary.totalSeconds,
    hourText: summary.hourText,
    minuteText: summary.minuteText,
    appCount: summary.appCount,
    topApps: topDtos,
    isNight: isNight,
    isWorkHour: isWorkHour,
    guardCount: guardCount
  }

  const userPrompt = buildPhoneUsageEvalPrompt(input)
  console.log('[PhoneUsageService] aiEvaluateTodayUsage prompt len=' + userPrompt.length)
  callMinimaxChat(SYSTEM_PROMPT_PHONE_USAGE, userPrompt, 600,
    (raw: string): void => {
      const cleaned = sanitizeAiEvalText(raw)
      if (cleaned.length < 1) {
        onComplete(getFallbackPhoneUsageEval())
        return
      }
      onComplete(cleaned)
    },
    (): void => {
      console.warn('[PhoneUsageService] aiEvaluateTodayUsage LLM 失败')
      onComplete(getFallbackPhoneUsageEval())
    }
  )
}

function sanitizeAiEvalText(raw: string): string {
  if (raw == null || raw.length < 1) return ''
  let s = raw.trim()
  // 去除 markdown 包裹
  if (s.startsWith('```')) {
    const firstNewline = s.indexOf('\n')
    if (firstNewline > 0) s = s.substring(firstNewline + 1)
    if (s.endsWith('```')) s = s.substring(0, s.length - 3)
  }
  s = s.trim()
  if (s.length < 1) return ''
  // 强制去除行内 emoji（保留末尾品牌签名 🌙）
  s = stripEmojiExceptBrand(s)
  // 限长 600
  if (s.length > 600) s = s.substring(0, 600)
  return s
}

// 去除 emoji 字符（保留 🌙 末尾品牌签名）
function stripEmojiExceptBrand(s: string): string {
  let out = ''
  for (let i = 0; i < s.length; i++) {
    const ch = s.charAt(i)
    if (ch == '🌙') {
      out = out + ch
      continue
    }
    // 简单的 emoji 范围过滤
    const code = s.charCodeAt(i)
    // 高位代理区（surrogate pair）跳过
    if (code != null && code >= 0xD800 && code <= 0xDBFF) {
      // 检查后一个是否为低代理
      const next = s.charAt(i + 1)
      const nextCode = next.charCodeAt(0)
      if (nextCode != null && nextCode >= 0xDC00 && nextCode <= 0xDFFF) {
        // 是 emoji 字符（4 字节 UTF-16 代理对）
        i++
        continue
      }
    }
    out = out + ch
  }
  return out
}

export type PhoneUsageFromSystem = {
  summary: PhoneUsageSummary
  segments: PieSegment[]
}

function startOfTodayMs(): number {
  const d = new Date()
  d.setHours(0, 0, 0, 0)
  return d.getTime()
}

type SystemUsageEntry = {
  packageName: string
  totalTimeInForeground: number
  lastTimeUsed: number
}

// 从系统 UsageStatsManager.queryUsageStats(todayStart, now) 直接读
// 用于本地 app_usage_snapshots 为空时的兜底显示
export function getPhoneUsageFromSystem(): PhoneUsageFromSystem {
  const emptySummary: PhoneUsageSummary = {
    totalMinutes: 0,
    totalSeconds: 0,
    hourText: '0 小时',
    minuteText: '0 分钟',
    appCount: 0
  }
  const startMs = startOfTodayMs()
  const endMs = Date.now()
  let entries: SystemUsageEntry[] = []
  try {
    const raw = queryUsageStatsOnce(startMs, endMs)
    if (raw != null) {
      for (let i = 0; i < raw.length; i++) {
        const e = raw[i]
        if (e == null) continue
        const item: SystemUsageEntry = {
          packageName: e.packageName,
          totalTimeInForeground: e.totalTimeInForeground as number,
          lastTimeUsed: e.lastTimeUsed as number
        }
        entries.push(item)
      }
    }
  } catch (e) {
    console.error('[PhoneUsageService] queryUsageStatsOnce 失败: ' + JSON.stringify(e))
    const emptyResult: PhoneUsageFromSystem = { summary: emptySummary, segments: [] }
    return emptyResult
  }
  if (entries.length < 1) {
    const emptyResult: PhoneUsageFromSystem = { summary: emptySummary, segments: [] }
    return emptyResult
  }

  // 转 AppUsageItem 列表
  const items: AppUsageItem[] = []
  for (let i = 0; i < entries.length; i++) {
    const e = entries[i]
    if (e == null) continue
    const sec = Math.floor((e.totalTimeInForeground as number) / 1000)
    const label = e.packageName != null ? e.packageName : ''
    items.push({
      packageName: e.packageName,
      appLabel: label,
      foregroundSec: sec,
      minutes: Math.floor(sec / 60)
    })
  }
  // 按 desc 排序
  items.sort((a: AppUsageItem, b: AppUsageItem): number => b.foregroundSec - a.foregroundSec)

  // 汇总秒数
  let totalSeconds = 0
  for (let i = 0; i < items.length; i++) {
    totalSeconds += items[i].foregroundSec
  }
  const totalMinutes = Math.floor(totalSeconds / 60)
  const hours = Math.floor(totalMinutes / 60)
  const remainMin = totalMinutes % 60
  const summary: PhoneUsageSummary = {
    totalMinutes: totalMinutes,
    totalSeconds: totalSeconds,
    hourText: hours + ' 小时',
    minuteText: remainMin + ' 分钟',
    appCount: items.length
  }

  if (totalSeconds < 1) {
    const noSegResult: PhoneUsageFromSystem = { summary, segments: [] }
    return noSegResult
  }

  // 构造 segments（与 getTodayPieSegments 同样的逻辑）
  const segments: PieSegment[] = []
  let start = 0
  const cap = items.length > 10 ? 10 : items.length
  for (let i = 0; i < cap; i++) {
    const item = items[i]
    const pct = (item.foregroundSec / totalSeconds) * 100
    const end = start + pct
    const color: string = i < PALETTE.length ? (PALETTE[i] as string) : '#BDC3C7'
    const seg: PieSegment = {
      pkg: item.packageName,
      label: item.appLabel.length > 0 ? item.appLabel : item.packageName,
      minutes: item.minutes,
      percent: Math.round(pct * 10) / 10,
      color: color,
      startAngle: start,
      endAngle: end
    }
    segments.push(seg)
    start = end
  }
  if (items.length > cap) {
    let othersMin = 0
    for (let i = cap; i < items.length; i++) {
      othersMin += items[i].minutes
    }
    const pct = 100 - start
    const seg: PieSegment = {
      pkg: '__others__',
      label: '其他',
      minutes: othersMin,
      percent: Math.round(pct * 10) / 10,
      color: '#BDC3C7',
      startAngle: start,
      endAngle: 100
    }
    segments.push(seg)
  }
  const finalResult: PhoneUsageFromSystem = { summary, segments }
  return finalResult
}

