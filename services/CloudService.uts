export type DailyData = {
  totalCompleted: number
  totalSkipped: number
  totalDurationSec: number
  guardMinutes: number
  guardCount: number
  penetration: number
  eyeScore: number
  postureScore: number
  vitalityScore: number
  todayCompletedCount: number
}

import { WeeklyReportStats } from '../models/WeeklyReport'
import { TriggerRule } from '../models/TriggerRule'
import { SYSTEM_PROMPT_EVALUATE, buildPreTriggerPrompt, buildPostActionPrompt, PreTriggerContext, PostActionContext } from '../constants/LlmPrompts'

const MINIMAX_BASE_URL = 'https://api.minimax.chat/v1'
const MINIMAX_CHAT_PATH = 'text/chatcompletion_v2'
const MINIMAX_CHAT_MODEL = 'MiniMax-M2.7'
const MINIMAX_API_KEY = 'sk-cp-Dd2_yFv0hINLsc2fnuWrrde0agYZQCzaRzW0DaK64CAl7Y-plAqRd7R2jSxQTSgSEWbl6teJc2oFL90HPMgyqLXel67OJhufLeLeVauln93DyXmA1277iQw'

type MinimaxBaseResp = {
  status_code?: number
  status_msg?: string
}

type MinimaxMessage = {
  content?: string
}

type MinimaxChoice = {
  message?: MinimaxMessage
}

type MinimaxChatResp = {
  base_resp?: MinimaxBaseResp
  choices?: MinimaxChoice[]
}

type CloudResponse = {
  code: number
  data: any
  error: string | null
}

export function callDaily(date: string, data: DailyData, onOK: (result: any) => void, onFail: () => void): void {
  callCloudFn('llm-daily', {
    date: date,
    data: {
      totalCompleted: data.totalCompleted,
      totalSkipped: data.totalSkipped,
      totalDurationSec: data.totalDurationSec,
      guardMinutes: data.guardMinutes,
      guardCount: data.guardCount,
      penetration: data.penetration,
      eyeScore: data.eyeScore,
      postureScore: data.postureScore,
      vitalityScore: data.vitalityScore
    }
  }, onOK, onFail)
}

export function callWeekly(data: WeeklyReportStats, onOK: (result: any) => void, onFail: () => void): void {
  callCloudFn('llm-weekly', {
    data: {
      totalCompleted: data.totalCompleted,
      totalDurationSec: data.totalDurationSec,
      avgPenetration: data.avgPenetration,
      avgGuardMinutes: data.avgGuardMinutes,
      bestDay: data.bestDay,
      bestDayCount: data.bestDayCount,
      worstDay: data.worstDay,
      worstDayCount: data.worstDayCount
    }
  }, onOK, onFail)
}

export function callRuleSuggest(data: any, onOK: (result: any) => void): void {
  const r = Math.random()
  if (r < 0.15) {
    const rule: TriggerRule = {
      id: 0,
      rule_type: 'frequency',
      trigger_type: 'app_duration',
      condition_json: '{}',
      action_weights_json: '{}',
      enabled: 1,
      priority: 1,
      source: 'ai_suggest',
      expires_at: null,
      created_at: Math.floor(Date.now() / 1000),
      updated_at: Math.floor(Date.now() / 1000)
    }
    onOK({ shouldSuggest: true, rule: rule })
  } else {
    onOK({ shouldSuggest: false, rule: null })
  }
}

export function callRuleRefine(data: any, onOK: (result: any) => void): void {
  onOK({ shouldAdjust: false, insight: '' })
}

export function callTtsProxy(text: string, onOK: (result: any) => void): void {
  onOK({ code: -1, error: 'TTS 暂未实现' })
}

type TtsAdhocOptions = {
  timeout: number
}

export function callTtsAdhoc(context: any, options: TtsAdhocOptions, onOK: (result: any) => void, onFail: () => void): void {
  onFail()
}

function callCloudFn(name: string, payload: any, onOK: (result: any) => void, onFail: () => void): void {
  try {
    const payloadStr = JSON.stringify(payload)
    uni.request({
      url: 'https://fc-mp-xxx.bspapp.com/' + name,
      method: 'POST',
      header: { 'Content-Type': 'application/json' },
      data: payloadStr,
      timeout: 15000,
      success(res) {
        try {
          const dataJson = JSON.stringify(res.data)
          const obj = JSON.parse(dataJson) as CloudResponse
          if (obj.code === 0 && obj.data != null) {
            onOK(obj.data)
          } else {
            onFail()
          }
        } catch (_) {
          onFail()
        }
      },
      fail(err) {
        onFail()
      }
    })
  } catch (_) {
    onFail()
  }
}

export function callLlmEvaluate(
  stage: 'pre' | 'post',
  contextJson: string,
  onOK: (raw: string) => void,
  onFail: () => void
): void {
  if (MINIMAX_API_KEY === 'PLACEHOLDER_KEY') {
    console.warn('[CloudService] MiniMax API key 未配置（仍为 PLACEHOLDER_KEY），走降级路径')
    onFail()
    return
  }

  let userPrompt = ''
  try {
    if (stage === 'pre') {
      const ctx = JSON.parse(contextJson) as PreTriggerContext
      userPrompt = buildPreTriggerPrompt(ctx)
    } else {
      const ctx = JSON.parse(contextJson) as PostActionContext
      userPrompt = buildPostActionPrompt(ctx)
    }
  } catch (_) {
    onFail()
    return
  }

  const reqBody = {
    model: MINIMAX_CHAT_MODEL,
    messages: [
      { role: 'system' as const, content: SYSTEM_PROMPT_EVALUATE, name: 'MiniMax AI' },
      { role: 'user' as const, content: userPrompt, name: '用户' }
    ],
    temperature: 0.7,
    max_completion_tokens: 400
  }

  try {
    uni.request({
      url: MINIMAX_BASE_URL + '/' + MINIMAX_CHAT_PATH,
      method: 'POST',
      header: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + MINIMAX_API_KEY
      },
      data: JSON.stringify(reqBody),
      timeout: 8000,
      success(res) {
        try {
          const data = res.data
          const content = extractChatContent(data != null ? data : '')
          if (content.length > 0) {
            onOK(content)
          } else {
            onFail()
          }
        } catch (_) {
          onFail()
        }
      },
      fail(_err) {
        onFail()
      }
    })
  } catch (_) {
    onFail()
  }
}

function extractChatContent(data: any): string {
  try {
    const dataStr = JSON.stringify(data)
    const obj = JSON.parse(dataStr) as MinimaxChatResp
    if (obj.base_resp != null && obj.base_resp.status_code != null && obj.base_resp.status_code != 0) {
      console.warn('[CloudService] MiniMax 返回非 0 状态: ' + (obj.base_resp.status_msg ?? ''))
      return ''
    }
    if (obj.choices != null && obj.choices.length > 0) {
      const first = obj.choices[0]
      if (first != null && first.message != null && first.message.content != null) {
        const c = first.message.content
        return typeof c === 'string' ? c : ''
      }
    }
  } catch (_) {}
  return ''
}
