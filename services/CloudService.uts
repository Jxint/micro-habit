const MINIMAX_BASE_URL = 'https://api.minimax.chat/v1'
const MINIMAX_CHAT_PATH = 'text/chatcompletion_v2'
const MINIMAX_CHAT_MODEL = 'MiniMax-M2.7'
const MINIMAX_API_KEY = 'sk-cp-Dd2_yFv0hINLsc2fnuWrrde0agYZQCzaRzW0DaK64CAl7Y-plAqRd7R2jSxQTSgSEWbl6teJc2oFL90HPMgyqLXel67OJhufLeLeVauln93DyXmA1277iQw'

const MINIMAX_TTS_URL = 'https://api.minimaxi.com/v1/t2a_v2'
const MINIMAX_TTS_MODEL = 'speech-02-hd'
const MINIMAX_TTS_VOICE_ID = 'male-qn-qingse'

export function callMinimaxChat(systemPrompt: string, userPrompt: string, maxTokens: number, onOK: (raw: string) => void, onFail: () => void): void {
  if (MINIMAX_API_KEY === 'PLACEHOLDER_KEY') {
    console.warn('[CloudService] MiniMax API key 未配置，走降级路径')
    onFail()
    return
  }

  const reqBody = {
    model: MINIMAX_CHAT_MODEL,
    messages: [
      { role: 'system', content: systemPrompt, name: 'MiniMax AI' },
      { role: 'user', content: userPrompt, name: '用户' }
    ],
    temperature: 0.7,
    max_completion_tokens: maxTokens,
    reasoning_effort: 'low'
  }

  try {
    uni.request({
      url: MINIMAX_BASE_URL + '/' + MINIMAX_CHAT_PATH,
      method: 'POST',
      header: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + MINIMAX_API_KEY
      },
      data: JSON.stringify(reqBody),
      timeout: 30000,
      success(res) {
        try {
          const data = res.data
          const statusCode = (data != null) ? (data as UTSJSONObject).get('base_resp') : null
          const finishReason = (data != null) ? extractFinishReason(data as UTSJSONObject) : ''
          console.log('[CloudService] callMinimaxChat response, finishReason=' + finishReason)
          const content = extractChatContent(data != null ? data : '')
          if (content.length > 0) {
            console.log('[CloudService] callMinimaxChat content OK, length=' + content.length)
            onOK(content)
          } else {
            console.warn('[CloudService] callMinimaxChat empty content, raw data=' + JSON.stringify(data))
            onFail()
          }
        } catch (_) {
          onFail()
        }
      },
      fail(_err) {
        console.warn('[CloudService] callMinimaxChat network fail: ' + JSON.stringify(_err))
        onFail()
      }
    })
  } catch (_) {
    onFail()
  }
}

export function callMinimaxTts(
  text: string,
  onOK: (audioUrl: string) => void,
  onFail: (errMsg: string) => void
): void {
  if (MINIMAX_API_KEY === 'PLACEHOLDER_KEY' || MINIMAX_API_KEY.length < 8) {
    onFail('MiniMax TTS key 未配置')
    return
  }
  if (text.length < 1) {
    onFail('TTS text 为空')
    return
  }
  const reqBody = {
    model: MINIMAX_TTS_MODEL,
    text: text,
    stream: false,
    voice_setting: { voice_id: MINIMAX_TTS_VOICE_ID, speed: 1, vol: 1, pitch: 0 },
    audio_setting: { sample_rate: 32000, bitrate: 128000, format: 'mp3', channel: 1 },
    output_format: 'url'
  }
  try {
    uni.request({
      url: MINIMAX_TTS_URL,
      method: 'POST',
      header: {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + MINIMAX_API_KEY
      },
      data: JSON.stringify(reqBody),
      timeout: 30000,
      success(res) {
        try {
          const data = res.data
          if (data == null) {
            onFail('TTS 响应为空')
            return
          }
          const obj = data as UTSJSONObject
          const baseResp = obj.get('base_resp')
          if (baseResp != null) {
            const brObj = baseResp as UTSJSONObject
            const sc = brObj.get('status_code')
            if (sc != null && sc != 0) {
              const sm = brObj.get('status_msg')
              onFail('TTS 返回非 0 状态: ' + (sm != null ? ('' + sm) : ''))
              return
            }
          }
          const dataField = obj.get('data')
          if (dataField == null) {
            onFail('TTS 响应无 data 字段')
            return
          }
          const dObj = dataField as UTSJSONObject
          const audioField = dObj.get('audio')
          if (audioField == null) {
            onFail('TTS 响应无 data.audio 字段')
            return
          }
          const audioUrl = '' + audioField
          if (audioUrl.length < 8 || audioUrl.indexOf('http') < 0) {
            onFail('TTS 响应 audio 非 url: ' + audioUrl.substring(0, 80))
            return
          }
          console.log('[CloudService] callMinimaxTts OK, textLen=' + text.length + ' urlLen=' + audioUrl.length)
          onOK(audioUrl)
        } catch (e) {
          const msg = e != null ? ('' + e) : 'null'
          onFail('TTS 响应解析异常: ' + msg)
        }
      },
      fail(_err) {
        const msg = _err != null ? ('' + _err) : 'null'
        console.warn('[CloudService] callMinimaxTts network fail: ' + msg)
        onFail('TTS 网络失败: ' + msg)
      }
    })
  } catch (e) {
    const msg = e != null ? ('' + e) : 'null'
    onFail('TTS 请求构造异常: ' + msg)
  }
}

export function downloadTtsAudio(
  url: string,
  cacheKey: string,
  onOK: (localPath: string) => void,
  onFail: (errMsg: string) => void
): void {
  if (url.length < 8) {
    onFail('downloadTtsAudio url 为空')
    return
  }
  if (cacheKey.length < 1) {
    onFail('downloadTtsAudio cacheKey 为空')
    return
  }
  // 直接用 uni.downloadFile 下载 MiniMax 返回的音频 URL
  // 不指定 filePath，让系统下载到临时目录，避免 _doc/ 写入权限问题
  try {
    uni.downloadFile({
      url: url,
      timeout: 60000,
      success: (dlRes): void => {
        try {
          if (dlRes.statusCode != 200) {
            onFail('TTS 下载 HTTP 状态: ' + dlRes.statusCode)
            return
          }
          const tempPath: string = dlRes.tempFilePath
          if (tempPath == null || tempPath.length < 1) {
            onFail('TTS 下载无 tempFilePath')
            return
          }
          // 不写缓存（避免 _doc 写权限问题），下次触发会重新下载
          console.log('[CloudService] downloadTtsAudio OK, cacheKey=' + cacheKey + ' tempPath=' + tempPath)
          onOK(tempPath)
        } catch (e) {
          const msg = e != null ? ('' + e) : 'null'
          onFail('TTS 下载处理异常: ' + msg)
        }
      },
      fail: (err): void => {
        const msg = err != null ? ('' + err) : 'null'
        console.warn('[CloudService] downloadFile fail: ' + msg)
        onFail('TTS 文件下载失败: ' + msg)
      }
    })
  } catch (e) {
    const msg = e != null ? ('' + e) : 'null'
    onFail('TTS 下载请求构造失败: ' + msg)
  }
}

export function callDaily(date: string, data: DailyData, onOK: (raw: string) => void, onFail: () => void): void {
  console.log('[CloudService] callDaily start, date=' + date)
  const userPrompt = buildDailySummaryPrompt(data)
  callMinimaxChat(SYSTEM_PROMPT_DAILY, userPrompt, 1500, (raw: string): void => {
    if (raw.length > 0) {
      console.log('[CloudService] callDaily OK, raw.length=' + raw.length)
      onOK(raw)
      return
    }
    console.warn('[CloudService] callDaily empty raw')
    onFail()
  }, () => {
    console.warn('[CloudService] callDaily failed, fallback to local')
    onFail()
  })
}

export function callWeekly(data: WeeklyReportStats, onOK: (raw: string) => void, onFail: () => void): void {
  console.log('[CloudService] callWeekly start, totalCompleted=' + data.totalCompleted)
  const userPrompt = buildWeeklyReportPrompt(data)
  callMinimaxChat(SYSTEM_PROMPT_WEEKLY, userPrompt, 2000, (raw: string): void => {
    if (raw.length > 0) {
      console.log('[CloudService] callWeekly OK, raw.length=' + raw.length)
      onOK(raw)
      return
    }
    console.warn('[CloudService] callWeekly empty raw')
    onFail()
  }, () => {
    console.warn('[CloudService] callWeekly failed, fallback to local')
    onFail()
  })
}

export function callLlmEvaluate(
  stage: 'pre' | 'post',
  ctx: PreTriggerContext | PostActionContext,
  onOK: (raw: string) => void,
  onFail: () => void
): void {
  // 缓存命中短路：相同 (stage, pkg, hourBucket, contBucket) 直接复用
  // 仅 pre 阶段构造缓存键：pre 有 appPackage + continuousMinutes，post 无
  let cacheKey = ''
  if (stage === 'pre') {
    const pCtx = ctx as PreTriggerContext
    const cacheCtx: LlmCacheContext = {
      appPackage: pCtx.appPackage,
      continuousMinutes: pCtx.continuousMinutes
    }
    cacheKey = buildLlmCacheKey(stage, cacheCtx)
  }
  if (cacheKey.length > 0) {
    try {
        const cached = getLlmCacheByKey(cacheKey)
      if (cached != null && cached.response.length > 0) {
        const nowSec = Math.floor(Date.now() / 1000)
        if (cached.expires_at <= 0 || cached.expires_at > nowSec) {
          console.log('[CloudService] callLlmEvaluate ' + stage + ' cache HIT key=' + cacheKey)
          onOK(cached.response)
          return
        }
      }
    } catch (e) {
      console.warn('[CloudService] callLlmEvaluate 读缓存异常: ' + (e != null ? ('' + e) : 'null'))
    }
  }
  let userPrompt = ''
  try {
    if (stage === 'pre') {
      const pCtx = ctx as PreTriggerContext
      userPrompt = buildPreTriggerPrompt(pCtx)
      console.log('[CloudService] callLlmEvaluate pre userPrompt len=' + userPrompt.length)
    } else {
      const pCtx = ctx as PostActionContext
      userPrompt = buildPostActionPrompt(pCtx)
      console.log('[CloudService] callLlmEvaluate post userPrompt len=' + userPrompt.length)
    }
  } catch (e) {
    const msg = e != null ? ('' + e) : 'null'
    console.warn('[CloudService] callLlmEvaluate prompt 构造失败: ' + msg)
    onFail()
    return
  }

  callMinimaxChat(SYSTEM_PROMPT_EVALUATE, userPrompt, 1500, (raw: string): void => {
    console.log('[CloudService] callLlmEvaluate ' + stage + ' OK, rawLen=' + raw.length + ' preview=' + raw.substring(0, 80))
    if (cacheKey.length > 0 && raw.length > 0) {
      try {
        const ttlSec = 24 * 60 * 60
        const expiresAt = Math.floor(Date.now() / 1000) + ttlSec
        saveLlmCache(cacheKey, stage, raw, expiresAt)
      } catch (e) {
        console.warn('[CloudService] callLlmEvaluate 写缓存异常: ' + (e != null ? ('' + e) : 'null'))
      }
    }
    onOK(raw)
  }, (): void => {
    console.warn('[CloudService] callLlmEvaluate ' + stage + ' FAIL')
    onFail()
  })
}

// 缓存上下文：仅 pre 阶段有意义（post 阶段无 appPackage / continuousMinutes）
type LlmCacheContext = {
  appPackage: string
  continuousMinutes: number
}

// 构造缓存键：阶段 + 包名 + 整点 + 30min 连续桶
function buildLlmCacheKey(stage: string, ctx: LlmCacheContext | null): string {
  try {
    if (ctx == null) return ''
    const pkg = ctx.appPackage.length > 0 ? ctx.appPackage : 'unknown'
    const dayMs = 24 * 60 * 60 * 1000
    const hourBucket = Math.floor((Date.now() % dayMs) / (60 * 60 * 1000))
    const contBucket = Math.floor(ctx.continuousMinutes / 30) * 30
    return stage + ':' + pkg + ':' + hourBucket + ':' + contBucket
  } catch (_) {
    return ''
  }
}

function extractChatContent(data: any): string {
  try {
    const obj = data as UTSJSONObject
    if (obj == null) return ''
    const baseResp = obj.get('base_resp')
    if (baseResp != null) {
      const brObj = baseResp as UTSJSONObject
      const sc = brObj.get('status_code')
      if (sc != null && sc != 0) {
        const sm = brObj.get('status_msg')
        console.warn('[CloudService] MiniMax 返回非 0 状态: ' + (sm != null ? '' + sm : ''))
        return ''
      }
    }
    const choicesRaw = obj.get('choices')
    if (choicesRaw == null) return ''
    const choices = choicesRaw as Array<UTSJSONObject>
    if (choices.length < 1) return ''
    const first = choices[0]
    if (first == null) return ''
    const message = first.get('message')
    if (message == null) return ''
    const msgObj = message as UTSJSONObject
    const content = msgObj.get('content')
    if (content != null) {
      const c = '' + content
      if (c.length > 0) return c
    }
    const rc = msgObj.get('reasoning_content')
    if (rc != null) {
      const r = '' + rc
      if (r.length > 0) return r
    }
  } catch (e) {
    console.warn('[CloudService] extractChatContent exception: ' + JSON.stringify(e))
  }
  return ''
}

function extractFinishReason(data: UTSJSONObject): string {
  try {
    const choices = data.get('choices')
    if (choices == null) return ''
    const arr = choices as Array<UTSJSONObject>
    if (arr.length < 1) return ''
    const first = arr[0]
    if (first == null) return ''
    const fr = first.get('finish_reason')
    if (fr == null) return ''
    return '' + fr
  } catch (_) {
    return ''
  }
}

function parseJsonThreeLevels(raw: string): UTSJSONObject | null {
  // 1) 整体直接 parse
  try {
    const first = JSON.parse(raw)
    if (first != null) {
      if (typeof first === 'string') {
        try {
          const second = JSON.parse(first as string)
          if (second != null && typeof second === 'object') return second as UTSJSONObject
        } catch (_) {}
      } else if (typeof first === 'object') {
        return first as UTSJSONObject
      }
    }
    return null
  } catch (e1) {
    console.warn('[CloudService] parseJsonThreeLevels 整体 parse 失败: ' + (e1 != null ? ('' + e1) : 'null'))
  }
  // 2) 去掉 markdown ```json ... ``` 包裹后 parse
  try {
    const stripped: string = raw
      .replace(/```json\s*/gi, '')
      .replace(/```/g, '')
      .trim()
    const direct = JSON.parse(stripped)
    if (direct != null && typeof direct === 'object') return direct as UTSJSONObject
    if (typeof direct === 'string') {
      const second = JSON.parse(direct)
      if (second != null && typeof second === 'object') return second as UTSJSONObject
    }
    return null
  } catch (e2) {
    console.warn('[CloudService] parseJsonThreeLevels 去 markdown 后失败: ' + (e2 != null ? ('' + e2) : 'null'))
  }
  // 3) 兜底：贪婪匹配首个 { 到末尾，取平衡 JSON
  try {
    const startIdx: number = raw.indexOf('{')
    if (startIdx < 0) return null
    let depth: number = 0
    let inStr: boolean = false
    let esc: boolean = false
    for (let i = startIdx; i < raw.length; i++) {
      const c = raw.charAt(i) as string
      if (esc) { esc = false; continue }
      if (c == '\\') { esc = true; continue }
      if (c == '"') { inStr = !inStr; continue }
      if (inStr) continue
      if (c == '{') depth++
      else if (c == '}') {
        depth--
        if (depth == 0) {
          const sub: string = raw.substring(startIdx, i + 1)
          const obj = JSON.parse(sub)
          if (obj != null && typeof obj === 'object') return obj as UTSJSONObject
          return null
        }
      }
    }
  } catch (e3) {
    console.warn('[CloudService] parseJsonThreeLevels 平衡匹配失败: ' + (e3 != null ? ('' + e3) : 'null'))
  }
  return null
}
