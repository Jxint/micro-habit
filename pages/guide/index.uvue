            <text class="step-hint">用来检测你正在使用哪个 App，以及连续使用了多久</text>
            <view class="step-actions">
              <text class="step-status" :class="usageEnabled ? 'status-on' : 'status-off'">{{ usageEnabled ? '已开启' : '未开启' }}</text>
              <view v-if="!usageEnabled" class="step-btn" @tap="openUsageAccess"><text class="step-btn-text">立即开启</text></view>
            </view>
