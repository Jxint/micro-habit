</template>

<script setup lang="uts">
import { putInt } from '../../database/SettingsDao'
import { isUsagePermissionGranted, openUsageAccessSettings } from '../../uni_modules/uts-usage-stats/utssdk/app-android/index'
import { hasOverlayPermission, requestOverlayPermission } from '../../uni_modules/uts-floating-overlay/utssdk/app-android/index'

const usageEnabled = ref<boolean>(isUsagePermissionGranted())
const overlayEnabled = ref<boolean>(hasOverlayPermission())
const selectedFocus = ref<string>('balance')
const demoStarted = ref<boolean>(false)

function selectFocus(v: string): void {
  selectedFocus.value = v
}

function startDemo(): void {
  demoStarted.value = true
}

function refreshPermissionStates(): void {
  usageEnabled.value = isUsagePermissionGranted()
  overlayEnabled.value = hasOverlayPermission()
}

function openUsageAccess(): void {
  console.log('[guide] openUsageAccess 被点击')
  try {
    openUsageAccessSettings()
  } catch (e) {
    console.warn('[guide] openUsageAccessSettings 异常: ' + JSON.stringify(e))
  }
  setTimeout(refreshPermissionStates, 800)
}

function openOverlay(): void {
  console.log('[guide] openOverlay 被点击')
  try {
    requestOverlayPermission()
  } catch (e) {
    console.warn('[guide] requestOverlayPermission 异常: ' + JSON.stringify(e))
  }
  setTimeout(refreshPermissionStates, 800)
}

function completeGuide(): void {
  putInt('guide_completed', 1)
  uni.reLaunch({
    url: '/pages/home/index'
  })
}

function startApp(): void {
  refreshPermissionStates()
  if (!usageEnabled.value) {
    uni.showToast({
      title: '请先开启使用情况权限',
      icon: 'none'
    })
    return
  }
  if (!overlayEnabled.value) {
    uni.showToast({
      title: '请先开启悬浮窗权限',
      icon: 'none'
    })
    return
  }
  completeGuide()
}

function skipGuide(): void {
  completeGuide()
}

onShow((): void => {
  refreshPermissionStates()
})
</script>

