            <text class="demo-copy-text">检测到眼睛电量有点低，要不要眨眼 10 秒？</text>
          </view>
          <view class="demo-btn" @tap="startDemo"><text class="demo-btn-text">{{ demoStarted ? '演示中' : '好啊' }}</text></view>
        </view>
        <view v-if="demoStarted" class="demo-flow">
          <view class="demo-progress-bar">
