        </view>

        <view class="step-row">
          <view class="step-badge badge-purple"><text class="step-badge-text">2</text></view>
          <view class="step-body">
            <text class="step-name">开启悬浮窗权限</text>
            <text class="step-hint">用来在其他 App 上方显示微动作提醒</text>
            <view class="step-actions">
              <text class="step-status" :class="overlayEnabled ? 'status-on' : 'status-off'">{{ overlayEnabled ? '已开启' : '未开启' }}</text>
              <view v-if="!overlayEnabled" class="step-btn" @tap="openOverlay"><text class="step-btn-text">立即开启</text></view>
            </view>
          </view>
        </view>

        <view class="step-row">
          <view class="step-badge badge-pink"><text class="step-badge-text">3</text></view>
          <view class="step-body">
            <text class="step-name">后台守护</text>
            <text class="step-hint">用来保持提醒服务稳定运行，不打扰你的正常使用</text>
          </view>
        </view>
      </view>

      <!-- ===== 演示一次 ===== -->
      <view class="card card-accent demo-section">
        <text class="section-title">演示一次</text>
        <text class="section-subtitle">假设你刷屏久了一点，小星球会这样提醒你。</text>
        <view class="demo-card">
          <view class="demo-planet-circle">
            <image class="demo-mascot" src="/static/images/micro-planet-mascot.png" mode="aspectFit"></image>
