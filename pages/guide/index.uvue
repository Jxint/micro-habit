      <!-- ===== CTA ===== -->
      <view class="cta-section">
        <view class="cta-primary" @tap="startApp"><text class="cta-primary-text">开始我的小星球</text></view>
        <view class="cta-secondary" @tap="skipGuide"><text class="cta-secondary-text">先逛逛</text></view>
      </view>

