<template>
  <view class="page">
    <view class="page-bg">
      <image class="page-bg-img" src="/static/images/micro-habit-page-bg.png" mode="aspectFill"></image>
    </view>
    <view class="bg-glow glow-purple"></view>
    <view class="bg-glow glow-blue"></view>
    <view class="bg-glow glow-pink"></view>
    <view class="sky-moon"></view>
    <view class="sky-cloud cloud-a"></view>
    <view class="sky-cloud cloud-b"></view>
    <view class="sky-star star-a"></view>
    <view class="sky-star star-b"></view>
    <view class="sky-star star-c"></view>
    <view class="sky-star star-d"></view>
    <view class="sky-star star-e"></view>
    <view class="sky-star star-f"></view>
    <view class="sky-star star-g"></view>
    <view class="sky-star star-h"></view>
    <view class="sky-star star-i"></view>
    <view class="sky-star star-j"></view>
    <view class="sky-star star-k"></view>
    <view class="sky-star star-l"></view>
    <view class="sky-star star-m"></view>
    <view class="sky-star star-n"></view>
    <view class="sky-star star-o"></view>
    <view class="sky-star star-p"></view>
    <view class="sky-star star-q"></view>
    <view class="sky-star star-r"></view>
    <view class="sky-star star-s"></view>
    <view class="sky-star star-t"></view>
    <scroll-view class="scroll-area" scroll-y="true">
      <view class="greeting-bar">
        <view class="greeting-header">
          <view class="greeting-left">
            <text class="brand-kicker">微憩星球</text>
            <text class="greeting-text">{{ greeting }}</text>
            <text class="greeting-date">{{ dateStr }}</text>
            <text class="greeting-hint">{{ greetingHint }}</text>
          </view>
          <view class="greeting-right">
            <view class="mini-planet" @tap="openPhoneDialog">
              <image class="mini-planet-img" src="/static/images/micro-planet-mascot.png" mode="aspectFit"></image>
            </view>
            <view class="settings-icon" @tap="goSettings">
              <text class="settings-icon-text">⚙</text>
            </view>
          </view>
        </view>
        <view class="phone-usage-hint" @tap="openPhoneDialog">
          <text class="phone-usage-hint-text">{{ phoneUsageHint }}</text>
        </view>
        <view class="hero-action-row">
          <view class="hero-stat-pill">
            <text class="hero-stat-num">{{ guardCount }}</text>
            <text class="hero-stat-label">次点亮</text>
          </view>
          <view class="hero-main-cta" @tap="startHeroAction">
            <text class="hero-main-cta-text">开始一个微动作</text>
          </view>
        </view>
      </view>

      <view class="planet-hero-card">
        <view class="planet-hero-copy">
          <text class="planet-eyebrow">今日已点亮</text>
          <view class="planet-count-row">
            <text class="planet-count">{{ guardCount }}</text>
            <text class="planet-count-unit">次</text>
          </view>
          <text class="planet-guard-text">{{ guardMinuteText }}</text>
          <text class="planet-kind-text">每一次短暂停顿，都是身体收到的善意</text>
        </view>
        <view class="planet-visual" :class="planetVisualClass">
          <view class="planet-ring" v-if="showPlanetRing"></view>
          <view class="planet-core" :class="planetCoreClass">
            <text class="planet-core-text">✦</text>
          </view>
          <view class="planet-particle particle-a" v-if="showPlanetParticles"></view>
          <view class="planet-particle particle-b" v-if="showPlanetParticles"></view>
          <view class="planet-particle particle-c" v-if="showPlanetParticles"></view>
        </view>
      </view>

      <view class="cockpit-grid">
        <view class="health-cluster">
          <view class="section-header-row compact-header">
            <text class="section-title">三颗健康星球</text>
            <text class="section-caption">护眼 · 体态 · 活力</text>
          </view>
          <StatusIndicator title="护眼" :percent="eyeScore" :status="eyeStatus" />
          <StatusIndicator title="体态" :percent="postureScore" :status="postureStatus" />
          <StatusIndicator title="活力" :percent="vitalityScore" :status="vitalityStatus" />
        </view>

        <view class="cockpit-side">
          <view class="penetration-section">
            <view class="penetration-copy">
              <text class="section-label">习惯渗透度</text>
              <text class="penetration-sub">星环正在慢慢变亮</text>
            </view>
            <view class="penetration-track">
              <view class="penetration-fill" :style="{ width: (penetration * 10 > 100 ? 100 : penetration * 10) + '%' }"></view>
            </view>
            <text class="penetration-value">{{ penetrationStr }}</text>
          </view>

          <view class="summary-card" v-if="dailySummary != null">
            <text class="summary-eyebrow">AI 今日判断</text>
            <text class="summary-oneliner">{{ summaryOneLiner }}</text>
            <text v-if="summaryBody.length > 0" class="summary-body">{{ summaryBody }}</text>
            <view v-if="summaryGoal.length > 0" class="summary-goal-row">
              <text class="summary-goal-label">明日轨道</text>
              <text class="summary-goal-text">{{ summaryGoal }}</text>
            </view>
            <text v-if="summaryEncourage.length > 0" class="summary-encourage">{{ summaryEncourage }}</text>
            <view class="ai-feedback-row">
              <view class="ai-feedback-chip"><text class="ai-feedback-text">有帮助</text></view>
              <view class="ai-feedback-chip"><text class="ai-feedback-text">不太准</text></view>
            </view>
          </view>
          <view class="summary-card summary-empty" v-else>
            <text class="summary-eyebrow">AI 今日判断</text>
            <text class="summary-empty-text">{{ summaryPlaceholder }}</text>
            <text class="summary-empty-hint">完成更多微动作后，我会更懂你的节奏</text>
          </view>
        </view>
      </view>

      <view class="recommend-section">
        <view class="section-header-row">
          <text class="section-title">今日推荐动作</text>
          <text class="section-caption">挑一个，让小星球亮一下</text>
        </view>
        <view v-if="recommendedActions.length < 1" class="empty-recommend">
          <text class="empty-text">暂无推荐</text>
        </view>
        <view v-for="(action, idx) in recommendedActions" :key="'r-' + idx" class="recommend-item" :class="idx == 0 ? 'recommend-main' : 'recommend-secondary'">
          <ActionCard
            :action-id="action.id"
            :action-name="action.name"
            :action-duration="Math.ceil(action.defaultDurationMs / 1000)"
            variant="recommend"
            @actionTap="startAction"
          />
        </view>
      </view>

      <view class="library-section">
        <view class="library-header">
          <text class="section-title">小动作仓库（{{ allActions.length }}）</text>
          <text class="library-hint">点选任意动作，给身体一个几秒钟的小空隙</text>
        </view>
        <view v-for="(action, idx) in allActions" :key="'a-' + idx" class="library-item">
          <ActionCard
            :action-id="action.id"
            :action-name="action.name"
            :action-duration="Math.ceil(action.defaultDurationMs / 1000)"
            variant="library"
            @actionTap="startAction"
          />
        </view>
      </view>

      <view class="achievement-section">
        <view class="achievement-header" @tap="toggleAchievementsCollapsed">
          <view class="achievement-title-wrap">
            <text class="achievement-title">成就栏</text>
            <text class="achievement-count">{{ unlockedCount }} / 12</text>
            <view v-if="newUnlockedCount > 0" class="achievement-red-dot"></view>
          </view>
          <text class="achievement-toggle">{{ achievementsCollapsed ? '展开' : '收起' }}</text>
        </view>
        <view v-if="achievementsCollapsed" class="achievement-collapsed-scroll">
          <scroll-view class="achievement-scroll-x" scroll-x="true" show-scrollbar="false">
            <view v-for="(a, i) in achievements" :key="'ac-' + i" class="achv-chip" :class="a.isUnlocked ? 'achv-chip-on' : 'achv-chip-off'" @tap="onAchievementChipTap(a)">
              <text class="achv-chip-icon">{{ a.def.icon }}</text>
              <text v-if="a.isUnlocked" class="achv-chip-mark">✓</text>
              <text v-else class="achv-chip-mark achv-chip-mark-lock">锁</text>
              <view v-if="a.isNew" class="achv-chip-newdot"></view>
            </view>
          </scroll-view>
        </view>
        <view v-else class="achievement-grid">
          <view v-for="(a, i) in achievements" :key="'ag-' + i" class="achv-grid-card" :class="a.isUnlocked ? 'achv-grid-on' : 'achv-grid-off'" @tap="onAchievementGridTap(a)">
            <text class="achv-grid-icon">{{ a.def.icon }}</text>
            <text class="achv-grid-name">{{ a.def.name }}</text>
            <text class="achv-grid-cat">{{ a.def.category }}</text>
            <text class="achv-grid-prog" v-if="a.isUnlocked">已达成</text>
            <text class="achv-grid-prog achv-grid-prog-off" v-else>{{ a.currentProgress }} / {{ a.def.threshold }}</text>
            <view v-if="a.isNew" class="achv-grid-newdot"></view>
          </view>
        </view>
      </view>

      <view class="light-record-card">
        <view class="light-record-header">
          <view class="light-record-icon">
            <text class="light-record-icon-text">✧</text>
          </view>
          <view class="light-record-copy">
            <text class="light-record-title">星球点亮记录</text>
            <text class="light-record-text">每个小格子，都是你照顾自己的一个瞬间。</text>
          </view>
        </view>
        <HeatmapCalendar :dates="homeHeatmapDates" :counts="homeHeatmapCounts" :height="260" />
      </view>
      <LlmHistoryCard :entries="llmHistoryEntries" />

      <view class="bottom-spacer" />
    </scroll-view>
    <PhoneUsageDialog :visible="showPhoneDialog" @close="closePhoneDialog" />
    <TriggerRuleDialog
      :visible="showRuleDialog"
      :action-name="ruleActionName"
      :time-window-start="ruleTimeWindowStart"
      :time-window-end="ruleTimeWindowEnd"
      :time-threshold-minutes="ruleTimeThresholdMinutes"
      :screen-cond-text="ruleScreenCondText"
      :reasoning="pendingReasoning"
      @close="closeRuleDialog"
      @accept="acceptRule"
      @decline="closeRuleDialog"
      @never-ask="neverAskRule"
    />
    <AchievementDetailDialog
      :visible="showAchvDetail"
      :achievement-icon="detailIcon"
      :achievement-name="detailName"
      :achievement-category="detailCat"
      :achievement-description="detailDesc"
      :is-unlocked="detailUnlocked"
      :unlocked-date="detailUnlockedDate"
      :reward-text="detailReward"
      :progress-text="detailProgressText"
      :progress-percent="detailProgressPercent"
      :history-text="detailHistoryText"
      @close="closeAchvDetail"
    />
    <AchievementUnlockDialog
      :visible="showAchvUnlock"
      :achievement-icon="unlockIcon"
      :achievement-name="unlockName"
      :achievement-description="unlockDesc"
      :reward-text="unlockReward"
      @close="onUnlockDismiss"
      @viewDetail="onUnlockViewDetail"
    />
  </view>
</template>

<script setup lang="uts">
import StatusIndicator from '../../components/StatusIndicator.uvue'
import ActionCard from '../../components/ActionCard.uvue'
import PhoneUsageDialog from '../../components/PhoneUsageDialog.uvue'
import LlmHistoryCard from '../../components/LlmHistoryCard.uvue'
import TriggerRuleDialog from '../../components/TriggerRuleDialog.uvue'
import HeatmapCalendar from '../../components/HeatmapCalendar.uvue'
import { useAppStore, DailyOutput } from '../../stores/appStore'
import { MicroAction } from '../../models/MicroAction'
import { LlmHistoryEntry } from '../../models/LlmHistoryEntry'
import { EffectiveTriggerRule, ScreenConditions } from '../../models/EffectiveTriggerRule'
import { AchievementItem } from '../../models/Achievement'
import { currentHour } from '../../utils/TimeUtils'
import { getEnabledActions } from '../../services/ActionManager'
import { getSetting, putBool, getInt, putInt, putSetting } from '../../database/SettingsDao'
import { setActionIdForNextPage } from '../../utils/NavigationHelper'
import { getActionById } from '../../constants/Actions'
import { getGreetingHint } from '../../constants/MicroPlanetCopy'
import { getAchievementDef } from '../../constants/Achievements'
import { getProgressText as computeProgressText } from '../../services/AchievementService'
import AchievementDetailDialog from '../../components/AchievementDetailDialog.uvue'
import AchievementUnlockDialog from '../../components/AchievementUnlockDialog.uvue'

const store = useAppStore()
const nowMs = ref<number>(Date.now())
const nowHour = ref<number>(currentHour())
let clockTimerId: number | null = null

const eyeScore = computed<number>(() : number => store.eyeScore.value)
const eyeStatus = computed<string>(() : string => store.eyeStatus.value)
const postureScore = computed<number>(() : number => store.postureScore.value)
const postureStatus = computed<string>(() : string => store.postureStatus.value)
const vitalityScore = computed<number>(() : number => store.vitalityScore.value)
const vitalityStatus = computed<string>(() : string => store.vitalityStatus.value)
const guardCount = computed<number>(() : number => store.guardCount.value)
const penetration = computed<number>(() : number => store.penetration.value)
const penetrationStr = computed<string>(() : string => penetration.value.toFixed(1))
const recommendedActions = computed<MicroAction[]>(() => store.recommendedActions.value)
const allActions = computed<MicroAction[]>(() => getEnabledActions())

const achievements = computed<AchievementItem[]>(() : AchievementItem[] => store.achievements.value)
const achievementsCollapsed = ref<boolean>(getInt('achievements_collapsed', 1) == 1)
const seenSet = ref<Set<string>>(new Set<string>())

const unlockedCount = computed<number>(() : number => {
  let n = 0
  for (let i = 0; i < achievements.value.length; i++) {
    const item = achievements.value[i]
    if (item != null && item.isUnlocked) n++
  }
  return n
})

const newUnlockedCount = computed<number>(() : number => {
  let n = 0
  for (let i = 0; i < achievements.value.length; i++) {
    const item = achievements.value[i]
    if (item != null && item.isUnlocked && !seenSet.value.has(item.def.id)) n++
  }
  return n
})

function refreshSeenSet(): void {
  try {
    const raw = getSetting('seen_achievements', '[]')
    const arr = JSON.parse(raw) as Array<any>
    const s = new Set<string>()
    if (arr != null) {
      for (let i = 0; i < arr.length; i++) {
        const v = arr[i]
        if (typeof v === 'string' && (v as string).length > 0) {
          s.add(v as string)
        }
      }
    }
    seenSet.value = s
  } catch (_) {
    seenSet.value = new Set<string>()
  }
}

function markAchievementSeen(id: string): void {
  const s = seenSet.value
  s.add(id)
  const arr: string[] = []
  s.forEach((v: string): void => { arr.push(v) })
  const json = '[' + arr.map((v: string): string => '"' + v + '"').join(',') + ']'
  try { putSetting('seen_achievements', json) } catch (_) {}
}

const showAchvDetail = ref<boolean>(false)
const detailItem = ref<AchievementItem | null>(null)
const detailIcon = ref<string>('')
const detailName = ref<string>('')
const detailCat = ref<string>('')
const detailDesc = ref<string>('')
const detailUnlocked = ref<boolean>(false)
const detailUnlockedDate = ref<string>('')
const detailReward = ref<string>('')
const detailProgressText = ref<string>('')
const detailProgressPercent = ref<number>(0)
const detailHistoryText = ref<string>('')

const showAchvUnlock = ref<boolean>(false)
const unlockIcon = ref<string>('')
const unlockName = ref<string>('')
const unlockDesc = ref<string>('')
const unlockReward = ref<string>('')
const unlockCurrentId = ref<string>('')

function toggleAchievementsCollapsed(): void {
  achievementsCollapsed.value = !achievementsCollapsed.value
  try { putInt('achievements_collapsed', achievementsCollapsed.value ? 1 : 0) } catch (_) {}
}

function openAchvDetail(item: AchievementItem): void {
  detailItem.value = item
  detailIcon.value = item.def.icon
  detailName.value = item.def.name
  detailCat.value = item.def.category
  detailDesc.value = item.def.description
  detailUnlocked.value = item.isUnlocked
  if (item.isUnlocked && item.unlockedAt > 0) {
    const d = new Date(item.unlockedAt * 1000)
    detailUnlockedDate.value = d.getFullYear() + '-' + ('' + (d.getMonth() + 1)).padStart(2, '0') + '-' + ('' + d.getDate()).padStart(2, '0')
  } else {
    detailUnlockedDate.value = ''
  }
  detailReward.value = item.def.rewardText
  const prog = computeProgressText(item)
  detailProgressText.value = prog.text
  detailProgressPercent.value = prog.percent
  detailHistoryText.value = item.def.historyText
  showAchvDetail.value = true
}

function closeAchvDetail(): void {
  showAchvDetail.value = false
  detailItem.value = null
}

function tryShowNextUnlock(): void {
  const pending = store.pendingUnlockIds.value
  if (pending.length < 1) return
  const firstId = pending[0] as string
  const def = getAchievementDef(firstId)
  if (def == null) {
    store.shiftPendingUnlock()
    tryShowNextUnlock()
    return
  }
  unlockIcon.value = def.icon
  unlockName.value = def.name
  unlockDesc.value = def.description
  unlockReward.value = def.rewardText
  unlockCurrentId.value = firstId
  showAchvUnlock.value = true
}

function onUnlockDismiss(): void {
  if (unlockCurrentId.value.length > 0) {
    markAchievementSeen(unlockCurrentId.value)
  }
  showAchvUnlock.value = false
  unlockCurrentId.value = ''
  store.shiftPendingUnlock()
  setTimeout((): void => {
    tryShowNextUnlock()
  }, 200)
}

function onUnlockViewDetail(): void {
  const firstId = unlockCurrentId.value
  if (firstId.length > 0) {
    markAchievementSeen(firstId)
  }
  showAchvUnlock.value = false
  unlockCurrentId.value = ''
  store.shiftPendingUnlock()
  setTimeout((): void => {
    for (let i = 0; i < achievements.value.length; i++) {
      const item = achievements.value[i]
      if (item != null && item.def.id == firstId) {
        openAchvDetail(item)
        break
      }
    }
    tryShowNextUnlock()
  }, 200)
}

function onAchievementChipTap(item: AchievementItem): void {
  if (item.isNew) markAchievementSeen(item.def.id)
  openAchvDetail(item)
}

function onAchievementGridTap(item: AchievementItem): void {
  if (item.isNew) markAchievementSeen(item.def.id)
  openAchvDetail(item)
}

function getHomeHeatmapDates(): string[] {
  const rows = store.heatmapData.value
  const out: string[] = []
  for (let i = 0; i < rows.length; i++) {
    const item = rows[i]
    if (item != null) out.push(item.date)
  }
  return out
}

function getHomeHeatmapCounts(): number[] {
  const rows = store.heatmapData.value
  const out: number[] = []
  for (let i = 0; i < rows.length; i++) {
    const item = rows[i]
    if (item != null) out.push(item.count)
  }
  return out
}

const homeHeatmapDates = computed<string[]>(getHomeHeatmapDates)
const homeHeatmapCounts = computed<number[]>(getHomeHeatmapCounts)

const dailySummary = computed<DailyOutput | null>(() : DailyOutput | null => store.dailySummary.value)
const dailySummaryLoading = computed<boolean>(() : boolean => store.dailySummaryLoading.value)
function getSummaryOneLiner(): string {
  const s = dailySummary.value
  return s != null && s.bodyText.length > 0 ? '今日小结已生成' : '今日小结待生成'
}
function getSummaryBody(): string {
  const s = dailySummary.value
  return s != null ? s.bodyText : ''
}
function getSummaryGoal(): string {
  return ''
}
function getSummaryEncourage(): string {
  return ''
}
function getSummaryHour(): number {
  const raw = getSetting('daily_summary_time', '21:00')
  const sep = raw.indexOf(':')
  const h = parseInt(sep > 0 ? raw.substring(0, sep) : raw)
  if (h < 0 || h > 23) return 21
  return h
}
function getSummaryPlaceholder(): string {
  if (dailySummaryLoading.value) return '正在生成今日小结…'
  const cnt = store.todayCompletedCount.value
  if (cnt < 1) return '完成一个微动作，开启今日小结'
  return '已完成' + cnt + '次，' + getSummaryHour() + ':00 后自动小结'
}

const summaryOneLiner = computed<string>(getSummaryOneLiner)
const summaryBody = computed<string>(getSummaryBody)
const summaryGoal = computed<string>(getSummaryGoal)
const summaryEncourage = computed<string>(getSummaryEncourage)
const summaryHour = computed<number>(getSummaryHour)
const summaryPlaceholder = computed<string>(getSummaryPlaceholder)

function getGreeting(): string {
  const h = nowHour.value
  if (h < 6) return '夜深了'
  if (h < 9) return '早上好'
  if (h < 12) return '上午好'
  if (h < 14) return '中午好'
  if (h < 18) return '下午好'
  if (h < 22) return '晚上好'
  return '夜深了'
}

function getGreetingEmoji(): string {
  const h = nowHour.value
  if (h < 6) return '🌙'
  if (h < 9) return '☀️'
  if (h < 12) return '☀️'
  if (h < 14) return '🌤'
  if (h < 18) return '⛅'
  if (h < 22) return '🌆'
  return '🌙'
}

const greeting = computed<string>(getGreeting)
const greetingEmoji = computed<string>(getGreetingEmoji)
const greetingHint = computed<string>(() : string => getGreetingHint(nowHour.value))

const phoneMinutes = computed<number>(() : number => store.phoneMinutes.value)
function getPhoneUsageHint(): string {
  if (phoneMinutes.value < 1) return '点击查看今日手机使用信号'
  return '今日已使用 ' + phoneMinutes.value + ' 分钟，看看星球信号'
}
const phoneUsageHint = computed<string>(getPhoneUsageHint)

function getGuardMinuteText(): string {
  if (guardCount.value < 1) return '今天的小星球还在等第一次点亮'
  return '已为你守护约 ' + guardCount.value + ' 分钟'
}

function getPlanetVisualClass(): string {
  const count = guardCount.value
  if (count < 1) return 'planet-dim'
  if (count < 4) return 'planet-soft'
  if (count < 9) return 'planet-ring-on'
  return 'planet-bright'
}

function getPlanetCoreClass(): string {
  if (guardCount.value < 1) return 'planet-core-dim'
  return 'planet-core-on'
}

function getShowPlanetRing(): boolean {
  return guardCount.value >= 4
}

function getShowPlanetParticles(): boolean {
  return guardCount.value >= 9
}

const guardMinuteText = computed<string>(getGuardMinuteText)
const planetVisualClass = computed<string>(getPlanetVisualClass)
const planetCoreClass = computed<string>(getPlanetCoreClass)
const showPlanetRing = computed<boolean>(getShowPlanetRing)
const showPlanetParticles = computed<boolean>(getShowPlanetParticles)

const showPhoneDialog = ref<boolean>(false)
const showRuleDialog = ref<boolean>(false)
const pendingRule = ref<EffectiveTriggerRule | null>(null)
const pendingReasoning = ref<string>('')

const ruleActionName = computed<string>(() : string => {
  const r = pendingRule.value
  if (r == null) return ''
  const a = getActionById(r.actionId)
  return a != null ? a.name : '微动作'
})
const ruleTimeWindowStart = computed<string>(() : string => {
  const r = pendingRule.value
  if (r == null || r.timeWindow == null) return ''
  return r.timeWindow.start
})
const ruleTimeWindowEnd = computed<string>(() : string => {
  const r = pendingRule.value
  if (r == null || r.timeWindow == null) return ''
  return r.timeWindow.end
})
const ruleTimeThresholdMinutes = computed<number>(() : number => {
  const r = pendingRule.value
  if (r == null) return 0
  return r.timeThresholdMinutes
})
const ruleScreenCondText = computed<string>(() : string => {
  const r = pendingRule.value
  if (r == null || r.screenConditions == null) return ''
  const sc = r.screenConditions
  const parts: string[] = []
  if (sc.includeHome) parts.push('桌面')
  if (sc.appPackages.length > 0) parts.push(sc.appPackages.join(', '))
  return parts.length > 0 ? parts.join(' / ') : '任意'
})

const llmHistoryEntries = computed<LlmHistoryEntry[]>(() : LlmHistoryEntry[] => store.llmHistory.value)

function openPhoneDialog(): void {
  showPhoneDialog.value = true
}

function closePhoneDialog(): void {
  showPhoneDialog.value = false
}

function closeRuleDialog(): void {
  showRuleDialog.value = false
  pendingRule.value = null
  pendingReasoning.value = ''
}

function acceptRule(): void {
  showRuleDialog.value = false
  pendingRule.value = null
  pendingReasoning.value = ''
  uni.showToast({ title: '规则已接受（持久化待 Day 5）', icon: 'none' })
}

function neverAskRule(): void {
  putBool('llm_trigger_ask_each_time', false)
  closeRuleDialog()
  uni.showToast({ title: '已关闭"每次问询"', icon: 'none' })
}

function getGreetingClass(): string {
  const h = nowHour.value
  if (h < 6) return 'bg-night'
  if (h < 9) return 'bg-morning'
  if (h < 14) return 'bg-noon'
  if (h < 18) return 'bg-afternoon'
  if (h < 22) return 'bg-evening'
  return 'bg-night'
}

function getDateStr(): string {
  const tick = nowMs.value
  if (tick < 1) return ''
  const d = new Date()
  const m = d.getMonth() + 1
  const day = d.getDate()
  const weekDays: string[] = ['日', '一', '二', '三', '四', '五', '六']
  return m + '月' + day + '日 · 星期' + weekDays[d.getDay()]
}

const greetingClass = computed<string>(getGreetingClass)
const dateStr = computed<string>(getDateStr)

function refreshClock(): void {
  nowMs.value = Date.now()
  nowHour.value = currentHour()
}

function clearClockTimer(): void {
  const tid = clockTimerId
  if (tid != null) {
    clearInterval(tid)
    clockTimerId = null
  }
}

function startClockTimer(): void {
  clearClockTimer()
  clockTimerId = setInterval((): void => {
    refreshClock()
  }, 60000)
}

onPageShow(() => {
  refreshClock()
  store.refreshHomeData()
  store.refreshLlmHistory()
  refreshSeenSet()
  store.refreshAchievements()
  setTimeout((): void => {
    tryShowNextUnlock()
  }, 500)
})

function startAction(actionId: string): void {
  setActionIdForNextPage(actionId)
  uni.navigateTo({
    url: '/pages/action/execute?actionId=' + actionId
  })
}

function startHeroAction(): void {
  const list = recommendedActions.value
  if (list.length > 0) {
    const first = list[0]
    if (first != null) {
      startAction(first.id)
      return
    }
  }
  const all = allActions.value
  if (all.length > 0) {
    const firstAll = all[0]
    if (firstAll != null) startAction(firstAll.id)
  }
}

function goSettings(): void {
  uni.switchTab({
    url: '/pages/settings/index'
  })
}

onLoad((): void => {
  refreshClock()
  startClockTimer()
  try {
    uni.$on('showTriggerRuleDialog', (data: any): void => {
      try {
        if (data == null) return
        const obj = data as UTSJSONObject
        if (obj == null) return
        const ruleRaw = obj['rule']
        const reasoningRaw = obj['reasoning']
        const ruleStr = JSON.stringify(ruleRaw)
        const rule = JSON.parse(ruleStr) as EffectiveTriggerRule
        if (rule == null) return
        pendingRule.value = rule
        const reasoning = typeof reasoningRaw === 'string' ? (reasoningRaw as string) : ''
        pendingReasoning.value = reasoning
        showRuleDialog.value = true
      } catch (e) {
        console.warn('[home] showTriggerRuleDialog 处理异常: ' + JSON.stringify(e))
      }
    })
  } catch (e) {
    console.warn('[home] $on showTriggerRuleDialog 异常: ' + JSON.stringify(e))
  }
  try {
    uni.$on('pendingAchievementUnlock', (data: any): void => {
      try {
        if (data == null) return
        const obj = data as UTSJSONObject
        if (obj == null) return
        const idsRaw = obj['ids']
        if (idsRaw == null) return
        const idsStr = JSON.stringify(idsRaw)
        const ids = JSON.parse(idsStr) as Array<any>
        if (ids == null || ids.length < 1) return
        const idArr: string[] = []
        for (let i = 0; i < ids.length; i++) {
          const v = ids[i]
          if (typeof v === 'string' && (v as string).length > 0) {
            idArr.push(v as string)
          }
        }
        if (idArr.length > 0) {
          store.setPendingUnlocks(idArr)
          tryShowNextUnlock()
        }
      } catch (e) {
        console.warn('[home] pendingAchievementUnlock 异常: ' + JSON.stringify(e))
      }
    })
  } catch (e) {
    console.warn('[home] $on pendingAchievementUnlock 异常: ' + JSON.stringify(e))
  }
})

onUnload((): void => {
  clearClockTimer()
})
</script>



