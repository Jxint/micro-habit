<template>
  <view class="page">
    <scroll-view class="scroll-area" scroll-y="true">
      <view class="greeting-bar" :class="greetingClass">
        <view class="greeting-header">
          <view class="greeting-left">
            <text class="greeting-text">{{ greeting }}</text>
            <text class="greeting-date">{{ dateStr }}</text>
          </view>
          <view class="greeting-right">
            <view class="emoji-button" @tap="openPhoneDialog">
              <text class="emoji-button-text">{{ greetingEmoji }}</text>
            </view>
            <view class="settings-icon" @tap="goSettings">
              <text class="settings-icon-text">⚙</text>
            </view>
          </view>
        </view>
        <view class="phone-usage-hint" @tap="openPhoneDialog">
          <text class="phone-usage-hint-text">{{ phoneUsageHint }}</text>
        </view>
      </view>

      <view class="guard-card">
        <text class="guard-eyebrow">今日已完成</text>
        <view class="guard-row">
          <text class="guard-number">{{ guardCount }}</text>
          <text class="guard-unit">次</text>
        </view>
        <text class="guard-sub">微动作累计 {{ guardCount }} 次 · 每一次都是对健康的投资</text>
      </view>

      <StatusIndicator
        title="护眼"
        :percent="eyeScore"
        :status="eyeStatus"
      />
      <StatusIndicator
        title="体态"
        :percent="postureScore"
        :status="postureStatus"
      />
      <StatusIndicator
        title="活力"
        :percent="vitalityScore"
        :status="vitalityStatus"
      />

      <view class="penetration-section">
        <text class="section-label">习惯渗透度</text>
        <view class="penetration-track">
          <view class="penetration-fill" :style="{ width: (penetration * 10 > 100 ? 100 : penetration * 10) + '%' }"></view>
        </view>
        <text class="penetration-value">{{ penetrationStr }}</text>
      </view>

      <view class="summary-card" v-if="dailySummary != null">
        <text class="summary-eyebrow">✨ 今日小结</text>
        <text class="summary-body">{{ summaryBodyText }}</text>
      </view>
      <view class="summary-card summary-empty" v-else>
        <text class="summary-empty-text">{{ summaryPlaceholder }}</text>
        <text class="summary-empty-hint">完成第一个微动作，自动生成今日小结</text>
      </view>

      <view class="recommend-section">
        <view class="section-header-row">
          <text class="section-title">🎯 今日推荐</text>
        </view>
        <view v-if="recommendedActions.length === 0" class="empty-recommend">
          <text class="empty-text">暂无推荐</text>
        </view>
        <view v-for="(action, idx) in recommendedActions" :key="'r-' + idx">
          <ActionCard
            :action-id="action.id"
            :action-name="action.name"
            :action-duration="Math.ceil(action.defaultDurationMs / 1000)"
            variant="recommend"
            @actionTap="startAction"
          />
        </view>
      </view>

      <view class="library-section">
        <view class="library-header">
          <text class="section-title">📚 全部微动作库（{{ allActions.length }}）</text>
          <text class="library-hint">点选任意动作立即开始</text>
        </view>
        <view v-for="(action, idx) in allActions" :key="'a-' + idx" class="library-item">
          <ActionCard
            :action-id="action.id"
            :action-name="action.name"
            :action-duration="Math.ceil(action.defaultDurationMs / 1000)"
            variant="library"
            @actionTap="startAction"
          />
        </view>
      </view>
      <LlmHistoryCard :entries="llmHistoryEntries" />

      <view class="bottom-spacer" />
    </scroll-view>
    <PhoneUsageDialog :visible="showPhoneDialog" @close="closePhoneDialog" />
    <TriggerRuleDialog
      :visible="showRuleDialog"
      :action-name="ruleActionName"
      :time-window-start="ruleTimeWindowStart"
      :time-window-end="ruleTimeWindowEnd"
      :time-threshold-minutes="ruleTimeThresholdMinutes"
      :screen-cond-text="ruleScreenCondText"
      :reasoning="pendingReasoning"
      @close="closeRuleDialog"
      @accept="acceptRule"
      @decline="closeRuleDialog"
      @never-ask="neverAskRule"
    />
  </view>
</template>

<script setup lang="uts">
import StatusIndicator from '../../components/StatusIndicator.uvue'
import ActionCard from '../../components/ActionCard.uvue'
import PhoneUsageDialog from '../../components/PhoneUsageDialog.uvue'
import LlmHistoryCard from '../../components/LlmHistoryCard.uvue'
import TriggerRuleDialog from '../../components/TriggerRuleDialog.uvue'
import { useAppStore, DailyOutput } from '../../stores/appStore'
import { MicroAction } from '../../models/MicroAction'
import { LlmHistoryEntry } from '../../models/LlmHistoryEntry'
import { EffectiveTriggerRule, ScreenConditions } from '../../models/EffectiveTriggerRule'
import { currentHour } from '../../utils/TimeUtils'
import { getEnabledActions } from '../../services/ActionManager'
import { getSetting, putBool } from '../../database/SettingsDao'
import { setActionIdForNextPage } from '../../utils/NavigationHelper'
import { getActionById } from '../../constants/Actions'

const store = useAppStore()

const eyeScore = computed<number>(() : number => store.eyeScore.value)
const eyeStatus = computed<string>(() : string => store.eyeStatus.value)
const postureScore = computed<number>(() : number => store.postureScore.value)
const postureStatus = computed<string>(() : string => store.postureStatus.value)
const vitalityScore = computed<number>(() : number => store.vitalityScore.value)
const vitalityStatus = computed<string>(() : string => store.vitalityStatus.value)
const guardCount = computed<number>(() : number => store.guardCount.value)
const penetration = computed<number>(() : number => store.penetration.value)
const penetrationStr = computed<string>(() : string => penetration.value.toFixed(1))
const recommendedActions = computed<MicroAction[]>(() => store.recommendedActions.value)
const allActions = computed<MicroAction[]>(() => getEnabledActions())

const dailySummary = computed<DailyOutput | null>(() : DailyOutput | null => store.dailySummary.value)
const dailySummaryLoading = computed<boolean>(() : boolean => store.dailySummaryLoading.value)
function getSummaryBodyText(): string {
  const s = dailySummary.value
  if (s == null) return ''
  return s.bodyText
}
function getSummaryPlaceholder(): string {
  if (dailySummaryLoading.value) return '正在生成今日小结…'
  const cnt = store.todayCompletedCount.value
  if (cnt < 1) return '完成一个微动作，开启今日小结'
  return '已完成' + cnt + '次，正在生成今日小结'
}

const summaryBodyText = computed<string>(getSummaryBodyText)
const summaryPlaceholder = computed<string>(getSummaryPlaceholder)

function getGreeting(): string {
  const h = currentHour()
  if (h < 6) return '夜深了'
  if (h < 9) return '早上好'
  if (h < 12) return '上午好'
  if (h < 14) return '中午好'
  if (h < 18) return '下午好'
  if (h < 22) return '晚上好'
  return '夜深了'
}

function getGreetingEmoji(): string {
  const h = currentHour()
  if (h < 6) return '🌙'
  if (h < 9) return '☀️'
  if (h < 12) return '☀️'
  if (h < 14) return '🌤'
  if (h < 18) return '⛅'
  if (h < 22) return '🌆'
  return '🌙'
}

const greeting = computed<string>(getGreeting)
const greetingEmoji = computed<string>(getGreetingEmoji)

const phoneMinutes = computed<number>(() : number => store.phoneMinutes.value)
function getPhoneUsageHint(): string {
  if (phoneMinutes.value < 1) return '👆 点击查看手机使用详情'
  return '今日已使用 ' + phoneMinutes.value + ' 分钟，点击查看详情 →'
}
const phoneUsageHint = computed<string>(getPhoneUsageHint)

const showPhoneDialog = ref<boolean>(false)
const showRuleDialog = ref<boolean>(false)
const pendingRule = ref<EffectiveTriggerRule | null>(null)
const pendingReasoning = ref<string>('')

const ruleActionName = computed<string>(() : string => {
  const r = pendingRule.value
  if (r == null) return ''
  const a = getActionById(r.actionId)
  return a != null ? a.name : r.actionId
})
const ruleTimeWindowStart = computed<string>(() : string => {
  const r = pendingRule.value
  if (r == null || r.timeWindow == null) return ''
  return r.timeWindow.start
})
const ruleTimeWindowEnd = computed<string>(() : string => {
  const r = pendingRule.value
  if (r == null || r.timeWindow == null) return ''
  return r.timeWindow.end
})
const ruleTimeThresholdMinutes = computed<number>(() : number => {
  const r = pendingRule.value
  if (r == null) return 0
  return r.timeThresholdMinutes
})
const ruleScreenCondText = computed<string>(() : string => {
  const r = pendingRule.value
  if (r == null || r.screenConditions == null) return ''
  const sc = r.screenConditions
  const parts: string[] = []
  if (sc.includeHome) parts.push('桌面')
  if (sc.appPackages.length > 0) parts.push(sc.appPackages.join(', '))
  return parts.length > 0 ? parts.join(' / ') : '任意'
})

const llmHistoryEntries = computed<LlmHistoryEntry[]>(() : LlmHistoryEntry[] => store.llmHistory.value)

function openPhoneDialog(): void {
  showPhoneDialog.value = true
}

function closePhoneDialog(): void {
  showPhoneDialog.value = false
}

function closeRuleDialog(): void {
  showRuleDialog.value = false
  pendingRule.value = null
  pendingReasoning.value = ''
}

function acceptRule(): void {
  showRuleDialog.value = false
  pendingRule.value = null
  pendingReasoning.value = ''
  uni.showToast({ title: '规则已接受（持久化待 Day 5）', icon: 'none' })
}

function neverAskRule(): void {
  putBool('llm_trigger_ask_each_time', false)
  closeRuleDialog()
  uni.showToast({ title: '已关闭"每次问询"', icon: 'none' })
}

function getGreetingClass(): string {
  const h = currentHour()
  if (h < 6) return 'bg-night'
  if (h < 9) return 'bg-morning'
  if (h < 14) return 'bg-noon'
  if (h < 18) return 'bg-afternoon'
  if (h < 22) return 'bg-evening'
  return 'bg-night'
}

function getDateStr(): string {
  const d = new Date()
  const m = d.getMonth() + 1
  const day = d.getDate()
  const weekDays: string[] = ['日', '一', '二', '三', '四', '五', '六']
  return m + '月' + day + '日 · 星期' + weekDays[d.getDay()]
}

const greetingClass = computed<string>(getGreetingClass)
const dateStr = computed<string>(getDateStr)

onPageShow(() => {
  store.refreshHomeData()
  store.refreshLlmHistory()
})

function startAction(actionId: string): void {
  setActionIdForNextPage(actionId)
  uni.navigateTo({
    url: '/pages/action/execute?actionId=' + actionId
  })
}

function goSettings(): void {
  uni.switchTab({
    url: '/pages/settings/index'
  })
}

onLoad((): void => {
  try {
    uni.$on('showTriggerRuleDialog', (data: any): void => {
      try {
        if (data == null) return
        const obj = data as UTSJSONObject
        if (obj == null) return
        const ruleRaw = obj['rule']
        const reasoningRaw = obj['reasoning']
        const ruleStr = JSON.stringify(ruleRaw)
        const rule = JSON.parse(ruleStr) as EffectiveTriggerRule
        if (rule == null) return
        pendingRule.value = rule
        const reasoning = typeof reasoningRaw === 'string' ? (reasoningRaw as string) : ''
        pendingReasoning.value = reasoning
        showRuleDialog.value = true
      } catch (e) {
        console.warn('[home] showTriggerRuleDialog 处理异常: ' + JSON.stringify(e))
      }
    })
  } catch (e) {
    console.warn('[home] $on showTriggerRuleDialog 异常: ' + JSON.stringify(e))
  }
})
</script>



