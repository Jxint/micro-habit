<template>
  <view class="page">
    <view class="bg-glow glow-purple"></view>
    <view class="bg-glow glow-blue"></view>
    <view class="bg-glow glow-pink"></view>
    <scroll-view class="scroll-area" scroll-y="true">
      <view class="settings-hero">
        <view class="settings-hero-copy">
          <text class="settings-kicker">微憩星球</text>
          <text class="settings-title">守护中心</text>
          <text class="settings-subtitle">你的小星球会记录节奏，提醒也会越来越懂你。</text>
        </view>
        <view class="settings-planet">
          <view class="settings-orbit"></view>
          <text class="settings-planet-text">◐</text>
        </view>
      </view>

      <view class="planet-note">
        <text class="planet-note-title">今日也可以只做一点点</text>
        <text class="planet-note-text">微动作不追求强度，只是在合适的时候，把你从屏幕里轻轻拉回来。</text>
      </view>

      <view class="settings-section">
        <text class="section-title">守护模式</text>
        <view class="setting-item">
          <view class="setting-left">
            <text class="setting-label">自动触发</text>
            <text class="setting-hint">开启后才会根据应用使用时长自动弹出微动作提醒</text>
          </view>
          <switch :checked="triggerEnabled" @change="onTriggerEnabledChange" />
        </view>
        <view class="setting-item" @tap="onManualTrigger">
          <view class="setting-left">
            <text class="setting-label">立即检查一次</text>
            <text class="setting-hint">主动查询当前 App 使用时长并判断是否触发微动作提醒</text>
          </view>
          <text class="setting-value">检查 ›</text>
        </view>
      </view>

      <view class="settings-section">
        <text class="section-title">AI 分析与提醒</text>
        <view class="setting-item" @tap="openDndPicker">
          <view class="setting-left">
            <text class="setting-label">免打扰时段</text>
            <text class="setting-hint">该时段不触发提醒</text>
          </view>
          <text class="setting-value">{{ dndStart }} - {{ dndEnd }} ›</text>
        </view>
        <view class="setting-item">
          <view class="setting-left">
            <text class="setting-label">启用 AI 实时建议</text>
            <text class="setting-hint">触发时生成轻量开场白，并复盘提醒规则</text>
          </view>
          <switch :checked="llmEnabled" @change="onLlmEnabledChange" />
        </view>
        <view class="setting-item">
          <view class="setting-left">
            <text class="setting-label">每次微动作后询问 AI 建议</text>
            <text class="setting-hint">关闭后默认接受 AI 建议，不再每次询问</text>
          </view>
          <switch :checked="askEachTime" :disabled="!llmEnabled" @change="onAskEachTimeChange" />
        </view>
      </view>

      <view class="settings-section">
        <text class="section-title">微动作设置</text>
        <view class="setting-item" @tap="openDurationPrefPicker">
          <view class="setting-left">
            <text class="setting-label">默认时长偏好</text>
            <text class="setting-hint">手动微动作的默认倒计时</text>
          </view>
          <text class="setting-value">{{ durationPref }} 秒 ›</text>
        </view>
        <view class="setting-item" @tap="openTargetCountPicker">
          <view class="setting-left">
            <text class="setting-label">每日目标次数</text>
            <text class="setting-hint">每类动作每天完成几次算满分</text>
          </view>
          <text class="setting-value">{{ targetCount }} 次 ›</text>
        </view>
      </view>

      <view class="settings-section">
        <text class="section-title">触发规则（{{ rules.length }} 条）</text>
        <view v-if="rules.length < 1" class="empty-rules">
          <text class="empty-text">暂无启用的触发规则</text>
          <text class="empty-hint">完成微动作后 AI 会自动建议规则</text>
        </view>
        <view v-for="(rule, idx) in rules" :key="'r-' + idx" class="rule-card">
          <view class="rule-row1">
            <text class="rule-type">{{ getActionDisplayName(rule.actionId) }}</text>
            <text class="rule-trigger">≥ {{ rule.timeThresholdMinutes }} 分钟</text>
            <text class="rule-priority">{{ formatTriggerLevel(rule.triggerLevel) }}</text>
          </view>
          <view class="rule-row2">
            <text class="rule-source">{{ formatSource(rule.source) }}</text>
            <text class="rule-cond">{{ formatAppPackages(rule.appPackages) }}{{ rule.timeWindow != null ? ' · ' + rule.timeWindow.start + '-' + rule.timeWindow.end : '' }}</text>
          </view>
          <view class="rule-row3">
            <text class="rule-time">创建 {{ formatTime(rule.createdAt) }}</text>
          </view>
        </view>
      </view>

      <view class="settings-section">
        <text class="section-title">App 分类</text>
        <view class="setting-item" @tap="goAppCategories">
          <view class="setting-left">
            <text class="setting-label">App 分类管理</text>
            <text class="setting-hint">手动调整每个 App 的分类，锁定后 LLM 不会覆盖</text>
          </view>
          <text class="setting-value">›</text>
        </view>
      </view>

      <view class="settings-section">
        <text class="section-title">调试</text>
        <view class="setting-item" @tap="goDebugLogs">
          <view class="setting-left">
            <text class="setting-label">查看触发/动作日志</text>
          </view>
          <text class="setting-value">›</text>
        </view>
        <view class="setting-item" @tap="goDebugDB">
          <view class="setting-left">
            <text class="setting-label">数据库巡检 & 配置</text>
          </view>
          <text class="setting-value">›</text>
        </view>
        <view class="setting-item" @tap="resetAchievements">
          <view class="setting-left">
            <text class="setting-label">重置成就进度</text>
            <text class="setting-hint">清空所有已解锁成就，可重新触发</text>
          </view>
          <text class="setting-value">›</text>
        </view>
      </view>

      <view class="settings-section">
        <text class="section-title">关于微憩星球</text>
        <view class="setting-item" @tap="handleDebugTap">
          <view class="setting-left">
            <text class="setting-label">版本号</text>
          </view>
          <text class="setting-value">1.0.0</text>
        </view>
      </view>
      <view class="bottom-spacer" />
    </scroll-view>

    <NumberPickerDialog
      :visible="showThresholdPicker"
      title="连续使用提醒阈值"
      hint="达到该连续时长（分钟）后弹窗提醒，建议 30-90 分钟"
      :initial-value="durationThreshold"
      :min-value="5"
      :max-value="180"
      :step="5"
      unit="分钟"
      :quick-values="[15, 30, 45, 60, 90, 120]"
      @close="showThresholdPicker = false"
      @confirm="onThresholdConfirm"
    />

    <TimeRangePickerDialog
      :visible="showDndPicker"
      title="免打扰时段"
      hint="起止小时（24小时制，分钟固定为 00）"
      :initial-start-hour="dndStartHour"
      :initial-end-hour="dndEndHour"
      @close="showDndPicker = false"
      @confirm="onDndConfirm"
    />

    <NumberPickerDialog
      :visible="showDurationPrefPicker"
      title="默认时长偏好"
      hint="手动微动作的默认倒计时秒数"
      :initial-value="durationPref"
      :min-value="5"
      :max-value="60"
      :step="1"
      unit="秒"
      :quick-values="[10, 15, 20, 30, 45, 60]"
      @close="showDurationPrefPicker = false"
      @confirm="onDurationPrefConfirm"
    />

    <NumberPickerDialog
      :visible="showTargetCountPicker"
      title="每日目标次数"
      hint="每类动作每天完成几次算 100 分"
      :initial-value="targetCount"
      :min-value="1"
      :max-value="20"
      :step="1"
      unit="次"
      :quick-values="[1, 2, 3, 5, 8, 10]"
      @close="showTargetCountPicker = false"
      @confirm="onTargetCountConfirm"
    />
  </view>
</template>

<script setup lang="uts">
import NumberPickerDialog from '../../components/NumberPickerDialog.uvue'
import TimeRangePickerDialog from '../../components/TimeRangePickerDialog.uvue'
import { getInt, putInt, getBool, putBool, getSetting, putSetting } from '../../database/SettingsDao'
import { clearAchievements } from '../../database/DatabaseHelper'
import { useAppStore } from '../../stores/appStore'
import { getActiveRules } from '../../database/EffectiveRuleDao'
import { PersistedEffectiveRule } from '../../models/PersistedEffectiveRule'
import { getActionById } from '../../constants/Actions'
import { setTriggerEnabled } from '../../uni_modules/uts-usage-stats/utssdk/app-android/index'

function pad2(n: number): string {
  if (n < 10) return '0' + n
  return '' + n
}

function parseHourFromSetting(v: string, def: number): number {
  if (v.length < 1) return def
  const parts = v.split(':')
  const h = parseInt(parts[0] as string)
  if (isNaN(h) || h < 0 || h > 23) return def
  return h
}

const durationThreshold = ref<number>(getInt('app_duration_threshold', 60))
const dndStartHour = ref<number>(parseHourFromSetting(getSetting('dnd_start', '22:00'), 22))
const dndEndHour = ref<number>(parseHourFromSetting(getSetting('dnd_end', '07:00'), 7))
const durationPref = ref<number>(getInt('action_duration_pref', 15))
const targetCount = ref<number>(getInt('category_target_count', 3))
const rules = ref<PersistedEffectiveRule[]>([])
const triggerEnabled = ref<boolean>(getBool('trigger_enabled', true))
const llmEnabled = ref<boolean>(getBool('llm_trigger_enabled', true))
const askEachTime = ref<boolean>(getBool('llm_trigger_ask_each_time', true))

const dndStart = computed<string>(() : string => pad2(dndStartHour.value) + ':00')
const dndEnd = computed<string>(() : string => pad2(dndEndHour.value) + ':00')

function formatTime(t: number): string {
  if (t <= 0) return '-'
  const d = new Date(t * 1000)
  return d.getFullYear() + '-' + pad2(d.getMonth() + 1) + '-' + pad2(d.getDate()) + ' ' + pad2(d.getHours()) + ':' + pad2(d.getMinutes())
}

function getActionDisplayName(actionId: string): string {
  const a = getActionById(actionId)
  return a != null ? a.name : actionId
}

function formatAppPackages(pkgs: string[]): string {
  if (pkgs.length < 1) return '任意 App'
  if (pkgs.length == 1) return pkgs[0] as string
  return pkgs.length + ' 个应用'
}

function formatRuleType(t: string): string {
  if (t.length < 1) return '时长控制'
  return t
}

function formatTriggerLabel(t: string): string {
  if (t === 'app_duration') return 'APP使用时长'
  if (t === 'manual') return '手动触发'
  if (t === 'scheduled') return '定时触发'
  return t
}

function formatSource(s: string): string {
  if (s === 'llm') return '🤖 LLM建议'
  if (s === 'user') return '👤 用户'
  if (s === 'system') return '📦 系统'
  return s
}

function formatTriggerLevel(level: string): string {
  if (level === 'gentle') return '轻提醒'
  if (level === 'strong') return '强提醒'
  if (level === 'night') return '夜间轻提醒'
  return level
}

function formatCondition(json: string): string {
  if (json.length < 1) return '无条件'
  try {
    const obj = JSON.parse(json) as UTSJSONObject
    if (obj == null) return json.substring(0, 20)
    const apps = obj.get('appPackages')
    const tw = obj.get('timeWindow')
    const parts: string[] = []
    if (apps != null) {
      const arr = apps as Array<any>
      if (arr.length > 0) {
        parts.push('包名 ' + (arr.length == 1 ? (arr[0] as string) : (arr.length + ' 个')))
      }
    }
    if (tw != null) {
      const twObj = tw as UTSJSONObject
      const s = twObj.get('start') as string
      const e = twObj.get('end') as string
      if (s != null && e != null) {
        parts.push('时段 ' + s + '-' + e)
      }
    }
    if (parts.length < 1) return json.substring(0, 20)
    return parts.join(' / ')
  } catch (_) {
    return json.substring(0, 20)
  }
}

const showThresholdPicker = ref<boolean>(false)
const showDndPicker = ref<boolean>(false)
const showDurationPrefPicker = ref<boolean>(false)
const showTargetCountPicker = ref<boolean>(false)

function openThresholdPicker(): void { showThresholdPicker.value = true }
function openDndPicker(): void { showDndPicker.value = true }
function openDurationPrefPicker(): void { showDurationPrefPicker.value = true }
function openTargetCountPicker(): void { showTargetCountPicker.value = true }

function onThresholdConfirm(v: number): void {
  durationThreshold.value = v
  putInt('app_duration_threshold', v)
  showThresholdPicker.value = false
  uni.showToast({ title: '已保存', icon: 'success' })
}

function onDndConfirm(s: number, e: number): void {
  dndStartHour.value = s
  dndEndHour.value = e
  putSetting('dnd_start', pad2(s) + ':00')
  putSetting('dnd_end', pad2(e) + ':00')
  showDndPicker.value = false
  uni.showToast({ title: '已保存', icon: 'success' })
}

function onDurationPrefConfirm(v: number): void {
  durationPref.value = v
  putInt('action_duration_pref', v)
  showDurationPrefPicker.value = false
  uni.showToast({ title: '已保存', icon: 'success' })
}

function onTargetCountConfirm(v: number): void {
  targetCount.value = v
  putInt('category_target_count', v)
  showTargetCountPicker.value = false
  uni.showToast({ title: '已保存', icon: 'success' })
}

function goDebugLogs(): void {
  uni.navigateTo({ url: '/pages/debug/logs' })
}

function goDebugDB(): void {
  uni.navigateTo({ url: '/pages/debug/logs' })
}

function resetAchievements(): void {
  try {
    uni.showModal({
      title: '确认重置',
      content: '清空所有成就解锁记录，重新开始统计。',
      success: (res) => {
        try {
          if (res == null) return
          const obj = res as UTSJSONObject
          if (obj == null) return
          const confirm = obj['confirm']
          if (confirm !== true) return
          clearAchievements()
          putSetting('seen_achievements', '[]')
          try { useAppStore().refreshAchievements() } catch (_) {}
          uni.showToast({ title: '已重置成就', icon: 'none' })
        } catch (e) {
          console.warn('[settings] resetAchievements 回调异常: ' + JSON.stringify(e))
        }
      }
    })
  } catch (e) {
    console.warn('[settings] resetAchievements 异常: ' + JSON.stringify(e))
  }
}

function goAppCategories(): void {
  uni.navigateTo({ url: '/pages/settings/app-categories/index' })
}

let debugTapCount = 0
let debugTapTimer: number | null = null

function handleDebugTap(): void {
  debugTapCount++
  const timerId = debugTapTimer
  if (timerId != null) { clearTimeout(timerId) }
  debugTapTimer = setTimeout((): void => { debugTapCount = 0 }, 3000)
  if (debugTapCount >= 5) {
    debugTapCount = 0
    putInt('app_duration_threshold', 1)
    uni.showToast({ title: 'Debug模式激活，阈值1分钟', position: 'bottom' })
  }
}

function onManualTrigger(): void {
  try {
    uni.$emit('manualTriggerCheck', {})
    uni.showToast({ title: '正在检查中', icon: 'none', position: 'bottom' })
  } catch (e) {
    console.warn('[settings] manualTrigger 异常: ' + JSON.stringify(e))
  }
}

function extractBoolFromSwitch(e: any): boolean | null {
  try {
    const obj = e as UTSJSONObject
    if (obj == null) return null
    const v = obj['detail']
    if (v == null) return null
    const detail = v as UTSJSONObject
    if (detail == null) return null
    const valRaw = detail['value']
    if (valRaw == null) return null
    if (typeof valRaw === 'boolean') return valRaw as boolean
    if (typeof valRaw === 'number') return (valRaw as number) != 0
    return null
  } catch (_) {
    return null
  }
}

function onTriggerEnabledChange(e: any): void {
  try {
    const enabled = extractBoolFromSwitch(e)
    if (enabled == null) return
    triggerEnabled.value = enabled
    putBool('trigger_enabled', enabled)
    setTriggerEnabled(enabled)
  } catch (err) {
    console.warn('[settings] onTriggerEnabledChange 异常: ' + JSON.stringify(err))
  }
}

function onLlmEnabledChange(e: any): void {
  try {
    const enabled = extractBoolFromSwitch(e)
    if (enabled == null) return
    llmEnabled.value = enabled
    putBool('llm_trigger_enabled', enabled)
  } catch (err) {
    console.warn('[settings] onLlmEnabledChange 异常: ' + JSON.stringify(err))
  }
}

function onAskEachTimeChange(e: any): void {
  try {
    const enabled = extractBoolFromSwitch(e)
    if (enabled == null) return
    askEachTime.value = enabled
    putBool('llm_trigger_ask_each_time', enabled)
  } catch (err) {
    console.warn('[settings] onAskEachTimeChange 异常: ' + JSON.stringify(err))
  }
}

onPageShow(() => {
  try { rules.value = getActiveRules() } catch (_) { rules.value = [] }
  durationThreshold.value = getInt('app_duration_threshold', 60)
  durationPref.value = getInt('action_duration_pref', 15)
  targetCount.value = getInt('category_target_count', 3)
  dndStartHour.value = parseHourFromSetting(getSetting('dnd_start', '22:00'), 22)
  dndEndHour.value = parseHourFromSetting(getSetting('dnd_end', '07:00'), 7)
  llmEnabled.value = getBool('llm_trigger_enabled', true)
  askEachTime.value = getBool('llm_trigger_ask_each_time', true)
  triggerEnabled.value = getBool('trigger_enabled', true)
})
</script>

<style scoped>
