.tag-pkg,
.tag-uses,
.empty-hint { color: rgba(255, 255, 255, 0.72); }
.dashboard-subtitle,
.settings-subtitle { font-size: 13px; line-height: 20px; margin-top: 8px; }
.dashboard-planet,
.settings-planet { position: relative; width: 86px; height: 86px; border-radius: 43px; background-color: rgba(219, 200, 237, 0.18); align-items: center; justify-content: center; }
.dashboard-orbit,
.settings-orbit { position: absolute; width: 96px; height: 34px; border-radius: 48px; border-width: 2px; border-color: rgba(219, 200, 237, 0.38); border-style: solid; transform: rotate(-20deg); }
.dashboard-planet-text,
.settings-planet-text { color: #DBC8ED; font-size: 34px; }
.planet-note { margin: 0 14px 12px 14px; padding: 16px 18px; border-radius: 24px; }
.planet-note-title { font-size: 16px; font-weight: bold; margin-bottom: 6px; }
.planet-note-text { font-size: 12px; line-height: 19px; }
.section,
.settings-section { margin: 12px 14px; border-radius: 24px; overflow: hidden; }
.section-header { flex-direction: row; justify-content: space-between; align-items: center; padding: 16px 18px 8px 18px; }
