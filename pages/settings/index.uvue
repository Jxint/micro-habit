.star-f { right: 86px; top: 420px; width: 4px; height: 4px; border-radius: 2px; }
.star-g { left: 138px; top: 610px; }
.star-h { right: 36px; top: 720px; width: 4px; height: 4px; border-radius: 2px; }
.star-i { left: 76px; top: 214px; width: 2px; height: 2px; border-radius: 1px; }
.star-j { right: 148px; top: 276px; width: 3px; height: 3px; border-radius: 2px; }
.star-k { left: 178px; top: 392px; width: 2px; height: 2px; border-radius: 1px; }
.star-l { right: 64px; top: 560px; width: 3px; height: 3px; border-radius: 2px; }

.dashboard-hero,
.settings-hero,
.planet-note,
.section,
.settings-section,
.guard-box,
.chart-container,
.report-stats,
.tag-card,
.header-block,
.filter-row,
.empty-block {
  background-color: rgba(29, 25, 62, 0.82);
  background-image: linear-gradient(135deg, rgba(48, 42, 94, 0.92) 0%, rgba(84, 65, 124, 0.72) 56%, rgba(198, 141, 192, 0.18) 100%);
  border-width: 1px;
  border-color: rgba(219, 200, 237, 0.18);
  border-style: solid;
  box-shadow: 0 18px 42px rgba(5, 6, 20, 0.28);
}
.dashboard-hero,
.settings-hero { margin: 22px 14px 12px 14px; padding: 22px 18px; border-radius: 28px; flex-direction: row; align-items: center; }
.dashboard-hero-copy,
.settings-hero-copy { flex: 1; flex-direction: column; padding-right: 12px; }
.dashboard-kicker,
.settings-kicker,
.section-toggle,
.setting-value,
.rule-priority,
.rule-source,
.detail-duration,
.guard-value,
.stat-val { color: #DBC8ED; }
