<template>
  <view class="page">
    <view class="header">
      <view class="header-left" @tap="goBack">
        <text class="header-back">‹</text>
      </view>
      <text class="header-title">调试日志</text>
      <view class="header-right" @tap="refresh">
        <text class="header-refresh">↻</text>
      </view>
    </view>

    <view class="stats-row">
      <view class="stat-card">
        <text class="stat-num">{{ triggerLogs.length }}</text>
        <text class="stat-label">今日触发</text>
      </view>
      <view class="stat-card">
        <text class="stat-num">{{ actionLogs.length }}</text>
        <text class="stat-label">今日动作</text>
      </view>
      <view class="stat-card">
        <text class="stat-num">{{ completedCount }}</text>
        <text class="stat-label">完成数</text>
      </view>
      <view class="stat-card">
        <text class="stat-num">{{ skippedCount }}</text>
        <text class="stat-label">跳过数</text>
      </view>
    </view>

    <view class="tab-bar">
      <view class="tab" :class="{ active: currentTab === 'trigger' }" @tap="switchTab('trigger')">
        <text class="tab-text">触发日志</text>
      </view>
      <view class="tab" :class="{ active: currentTab === 'action' }" @tap="switchTab('action')">
        <text class="tab-text">动作日志</text>
      </view>
      <view class="tab" :class="{ active: currentTab === 'db' }" @tap="switchTab('db')">
        <text class="tab-text">数据库</text>
      </view>
      <view class="tab" :class="{ active: currentTab === 'config' }" @tap="switchTab('config')">
        <text class="tab-text">配置</text>
      </view>
    </view>

    <scroll-view class="log-scroll" scroll-y="true">
      <view v-if="currentTab === 'trigger'">
        <view v-if="triggerLogs.length < 1" class="empty">
          <text class="empty-text">今日暂无触发记录</text>
          <text class="empty-hint">去使用某个 App 1 分钟以上会触发提醒</text>
        </view>
        <view v-for="(log, idx) in triggerLogs" :key="log.id" class="log-item">
          <view class="log-row1">
            <text class="log-time">{{ formatTime(log.created_at) }}</text>
            <text class="log-tag" :class="'tag-' + log.trigger_type">{{ formatTriggerType(log.trigger_type) }}</text>
            <text class="log-level">{{ formatTriggerLevel(log.trigger_level) }}</text>
          </view>
          <view class="log-row2">
            <text class="log-field-label">动作：</text>
            <text class="log-field-val">{{ formatActionId(log.action_id) }}</text>
          </view>
          <view class="log-row2">
            <text class="log-field-label">App：</text>
            <text class="log-field-val">{{ formatStr(log.app_package) }}</text>
            <text class="log-field-label" style="margin-left:12px;">连续：</text>
            <text class="log-field-val">{{ log.continuous_minutes }}分</text>
          </view>
          <view class="log-row3">
            <text class="log-field-label">用户操作：</text>
            <text class="log-user-action" :class="'ua-' + log.user_action">{{ formatUserAction(log.user_action) }}</text>
          </view>
        </view>
      </view>

      <view v-if="currentTab === 'action'">
        <view v-if="actionLogs.length < 1" class="empty">
          <text class="empty-text">今日暂无动作记录</text>
          <text class="empty-hint">点击首页"全部微动作库"开始第一次动作</text>
        </view>
        <view v-for="(log, idx) in actionLogs" :key="log.id" class="log-item">
          <view class="log-row1">
            <text class="log-time">{{ formatTime(log.created_at) }}</text>
            <text class="log-tag" :class="'tag-' + log.trigger_type">{{ formatTriggerType(log.trigger_type) }}</text>
            <text class="log-result" :class="'res-' + log.result">{{ formatResult(log.result) }}</text>
          </view>
          <view class="log-row2">
            <text class="log-field-label">动作ID：</text>
            <text class="log-field-val">{{ formatActionId(log.action_id) }}</text>
            <text class="log-field-label" style="margin-left:12px;">分类：</text>
            <text class="log-field-val">{{ formatActionType(log.action_type) }}</text>
          </view>
          <view class="log-row2">
            <text class="log-field-label">用时：</text>
            <text class="log-field-val">{{ formatDuration(log.duration_ms) }} / {{ formatDuration(log.target_ms) }}</text>
            <text class="log-field-label" style="margin-left:12px;">等级：</text>
            <text class="log-field-val">{{ formatTriggerLevel(log.trigger_level) }}</text>
          </view>
          <view v-if="log.skip_reason != null && log.skip_reason.length > 0" class="log-row3">
            <text class="log-field-label">跳过原因：</text>
            <text class="log-skip-reason">{{ formatSkipReason(log.skip_reason) }}</text>
          </view>
        </view>
      </view>

      <view v-if="currentTab === 'db'">
        <view class="section-header">
          <text class="section-header-text">数据库表概览</text>
        </view>
        <view v-for="(info, idx) in dbTableInfos" :key="idx" class="db-table-card">
          <view class="db-table-row">
            <text class="db-table-name">{{ formatTableName(info.name) }}</text>
            <text class="db-table-count">{{ info.count }} 行</text>
          </view>
        </view>
        <view class="section-header">
          <text class="section-header-text">最新动作日志（最近5条）</text>
        </view>
        <view v-for="(log, idx) in dbRecentActions" :key="'ra-' + idx" class="log-item">
          <view class="log-row1">
            <text class="log-time">{{ formatTime(log.created_at) }}</text>
            <text class="log-tag tag-manual">{{ formatActionId(log.action_id) }}</text>
            <text class="log-result" :class="'res-' + log.result">{{ formatResult(log.result) }}</text>
          </view>
          <view class="log-row2">
            <text class="log-field-val">{{ formatActionType(log.action_type) }} · {{ formatDuration(log.duration_ms) }} · {{ formatTriggerType(log.trigger_type) }}</text>
          </view>
        </view>
      </view>

      <view v-if="currentTab === 'config'">
        <view class="section-header">
          <text class="section-header-text">用户设置</text>
        </view>
        <view v-if="configList.length < 1" class="empty">
          <text class="empty-text">暂无配置数据</text>
        </view>
        <view v-for="(item, idx) in configList" :key="idx" class="config-item">
          <view class="config-row">
            <text class="config-key">{{ formatConfigKey(item.key) }}</text>
            <text class="config-val">{{ formatConfigValue(item.key, item.value) }}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</template>

<script setup lang="uts">
import { getTodayTriggerLogs } from '../../database/TriggerLogDao'
import { getTodayLogs, countCompletedToday, countSkippedToday } from '../../database/ActionLogDao'
import { TriggerLog, UserAction } from '../../models/TriggerLog'
import { ActionLog, ActionResult } from '../../models/ActionLog'
import { dbManager } from '../../database/DatabaseManager'
import { getActionById } from '../../constants/Actions'

const triggerLogs = ref<TriggerLog[]>([])
const actionLogs = ref<ActionLog[]>([])
const completedCount = ref<number>(0)
const skippedCount = ref<number>(0)
const currentTab = ref<string>('trigger')

const KNOWN_TABLES: string[] = [
  'action_logs', 'trigger_logs', 'user_settings',
  'daily_summaries', 'app_usage_snapshots',
  'tts_cache', 'heartbeat_logs', 'llm_cache',
  'llm_history', 'app_tags', 'effective_rules'
]

type DbTableInfo = { name: string, count: number }
const dbTableInfos = ref<DbTableInfo[]>([])
const dbRecentActions = ref<ActionLog[]>([])

type ConfigItem = { key: string, value: string }
const configList = ref<ConfigItem[]>([])

function pad2(n: number): string {
  return n < 10 ? '0' + n : '' + n
}

function formatTime(t: number): string {
  if (t == null || t <= 0) return '-'
  const d = new Date(t * 1000)
  const yyyy = d.getFullYear()
  const mm = d.getMonth() + 1
  const dd = d.getDate()
  const hh = d.getHours()
  const mi = d.getMinutes()
  const ss = d.getSeconds()
  return yyyy + '-' + pad2(mm) + '-' + pad2(dd) + ' ' + pad2(hh) + ':' + pad2(mi) + ':' + pad2(ss)
}

function formatDuration(ms: number): string {
  if (ms == null || ms <= 0) return '0秒'
  const s = Math.floor(ms / 1000)
  if (s < 60) return s + '秒'
  const m = Math.floor(s / 60)
  return m + '分' + (s % 60) + '秒'
}

function formatStr(s: string | null): string {
  if (s == null || s.length < 1) return '-'
  return s
}

function formatTriggerType(t: string): string {
  if (t === 'app_duration') return 'APP时长'
  if (t === 'manual') return '手动'
  if (t === 'scheduled') return '定时'
  if (t === 'time_period') return '时段'
  if (t === 'usage_threshold') return '阈值'
  if (t === 'app_switch') return '切换'
  return t
}

function formatActionId(id: string | null): string {
  if (id == null || id.length < 1) return '-'
  const a = getActionById(id)
  if (a != null) return a.name
  if (id === 'eye_blink') return '眨眼休息'
  if (id === 'eye_rotate') return '眼球转动'
  if (id === 'far_gaze') return '远眺放松'
  if (id === 'neck_rotate') return '颈部转动'
  if (id === 'shoulder_roll') return '肩膀绕环'
  if (id === 'neck_stretch') return '肩颈拉伸'
  if (id === 'core_tighten') return '核心收紧'
  if (id === 'heel_raise') return '踮脚唤醒'
  if (id === 'deep_breath') return '减压呼吸'
  return id
}

function formatActionType(t: string | null): string {
  if (t == null || t.length < 1) return '-'
  if (t === 'eye') return '护眼'
  if (t === 'posture') return '体态'
  if (t === 'vitality') return '活力'
  if (t === 'breath') return '呼吸'
  if (t === 'neck_shoulder') return '肩颈'
  if (t === 'core') return '核心'
  if (t === 'lower_body') return '下肢'
  return t
}

function formatTriggerLevel(level: string | null): string {
  if (level == null || level.length < 1) return '-'
  if (level === 'gentle') return '轻提醒'
  if (level === 'strong') return '强提醒'
  if (level === 'night') return '夜间轻提醒'
  return level
}

function formatSkipReason(reason: string | null): string {
  if (reason == null || reason.length < 1) return '-'
  if (reason === 'busy') return '正在忙'
  if (reason === 'too_hard') return '动作有点难'
  if (reason === 'bad_timing') return '时间不合适'
  if (reason === 'dont_want') return '现在不想做'
  if (reason === 'other') return '其他原因'
  return reason
}

function formatTableName(name: string): string {
  if (name === 'action_logs') return '动作记录'
  if (name === 'trigger_logs') return '提醒触发记录'
  if (name === 'user_settings') return '用户设置'
  if (name === 'daily_summaries') return '每日小结'
  if (name === 'trigger_rules') return '提醒规则'
  if (name === 'app_usage_snapshots') return 'App 使用快照'
  if (name === 'tts_cache') return '语音缓存'
  if (name === 'heartbeat_logs') return '守护心跳记录'
  if (name === 'llm_cache') return 'AI 缓存'
  return name
}

function formatConfigKey(key: string): string {
  if (key === 'action_duration_pref') return '默认动作时长'
  if (key === 'category_target_count') return '每日目标次数'
  if (key === 'dnd_start') return '免打扰开始'
  if (key === 'dnd_end') return '免打扰结束'
  if (key === 'guide_completed') return '引导页状态'
  if (key === 'llm_trigger_enabled') return 'AI 实时建议'
  if (key === 'llm_trigger_ask_each_time') return '每次询问 AI 建议'
  if (key === 'app_duration_threshold') return '连续使用提醒阈值'
  if (key === 'trigger_enabled') return '自动触发'
  return key
}

function formatConfigValue(key: string, value: string): string {
  if (key === 'guide_completed') return value === '1' ? '已完成' : '未完成'
  if (key === 'llm_trigger_enabled' || key === 'llm_trigger_ask_each_time' || key === 'trigger_enabled') {
    return value === 'true' || value === '1' ? '开启' : '关闭'
  }
  if (key === 'action_duration_pref') return value + ' 秒'
  if (key === 'category_target_count') return value + ' 次'
  if (key === 'app_duration_threshold') return value + ' 分钟'
  return value
}

function formatUserAction(ua: UserAction | null): string {
  if (ua == null) return '未响应'
  if (ua === 'completed') return '完成'
  if (ua === 'self_reported') return '自我报告'
  if (ua === 'skipped') return '跳过'
  if (ua === 'feedback') return '反馈'
  if (ua === 'ignored') return '忽略'
  if (ua === 'timeout') return '超时'
  if (ua === 'busy_remind_later') return '忙，稍后'
  return ua
}

function formatResult(r: ActionResult): string {
  if (r === 'completed') return '完成'
  if (r === 'self_reported') return '已做'
  if (r === 'skipped') return '跳过'
  if (r === 'feedback') return '反馈'
  return r
}

function loadDbOverview(): void {
  const infos: DbTableInfo[] = []
  for (let i = 0; i < KNOWN_TABLES.length; i++) {
    const t = KNOWN_TABLES[i]
    try {
      const row = dbManager.queryOne('SELECT COUNT(*) AS cnt FROM ' + t, [])
      const rawCnt = row != null ? row.get("cnt") : null
      const cnt: number = rawCnt != null ? parseFloat('' + rawCnt) : 0
      infos.push({ name: t, count: cnt })
    } catch (e) {
      console.error('[debug] loadDbOverview count error for ' + t + ': ' + e)
      infos.push({ name: t, count: 0 })
    }
  }
  dbTableInfos.value = infos

  try {
    const raw = dbManager.query('SELECT * FROM action_logs ORDER BY created_at DESC LIMIT 5', [])
    const logs: ActionLog[] = []
    for (let i = 0; i < raw.length; i++) {
      const r = raw[i]
      logs.push({
        id: r.get("id") as number,
        action_id: r.get("action_id") as string,
        action_type: r.get("action_type") as string,
        result: r.get("result") as ActionResult,
        skip_reason: r.get("skip_reason") as string | null,
        trigger_type: r.get("trigger_type") as string,
        trigger_level: r.get("trigger_level") as string,
        duration_ms: r.get("duration_ms") as number,
        target_ms: r.get("target_ms") as number,
        triggered_at: r.get("triggered_at") as number,
        completed_at: r.get("completed_at") as number,
        created_at: r.get("created_at") as number
      })
    }
    dbRecentActions.value = logs
  } catch (_) {
    dbRecentActions.value = []
  }
}

function loadConfig(): void {
  try {
    const raw = dbManager.query('SELECT key, value FROM user_settings ORDER BY key ASC', [])
    const items: ConfigItem[] = []
    for (let i = 0; i < raw.length; i++) {
      const r = raw[i]
      items.push({ key: r.get("key") as string, value: r.get("value") as string })
    }
    configList.value = items
  } catch (_) {
    configList.value = []
  }
}

function refresh(): void {
  try {
    triggerLogs.value = getTodayTriggerLogs()
    console.log('[debug] triggerLogs count=' + triggerLogs.value.length)
  } catch (e) {
    console.error('[debug] getTodayTriggerLogs error: ' + e)
    triggerLogs.value = []
  }
  try {
    actionLogs.value = getTodayLogs()
    console.log('[debug] actionLogs count=' + actionLogs.value.length)
  } catch (e) {
    console.error('[debug] getTodayLogs error: ' + e)
    actionLogs.value = []
  }
  try { completedCount.value = countCompletedToday() } catch (e) { console.error('[debug] countCompletedToday error: ' + e); completedCount.value = 0 }
  try { skippedCount.value = countSkippedToday() } catch (e) { console.error('[debug] countSkippedToday error: ' + e); skippedCount.value = 0 }
  loadDbOverview()
  loadConfig()
}

function switchTab(tab: string): void {
  currentTab.value = tab
}

function goBack(): void {
  uni.navigateBack({})
}

onPageShow(() => {
  console.log('[debug] onPageShow firing refresh')
  refresh()
})
</script>

<style scoped>
.page { flex: 1; background-color: #162038; background-image: linear-gradient(180deg, #131832 0%, #283252 45%, #4F587D 100%); position: relative; overflow: hidden; }
.header,
.stats-row,
.tab-bar,
.log-item,
.db-table-card,
.config-item { background-color: rgba(29, 25, 62, 0.82); background-image: linear-gradient(135deg, rgba(48, 42, 94, 0.92) 0%, rgba(84, 65, 124, 0.72) 56%, rgba(198, 141, 192, 0.18) 100%); border-width: 1px; border-color: rgba(219, 200, 237, 0.18); border-style: solid; box-shadow: 0 14px 32px rgba(5, 6, 20, 0.28); }
.header { flex-direction: row; align-items: center; justify-content: space-between; padding: 14px 16px; padding-top: 50px; border-bottom-width: 0; }
.header-left,
.header-right { width: 34px; height: 34px; border-radius: 17px; background-color: rgba(255, 255, 255, 0.1); align-items: center; justify-content: center; }
.header-back,
.header-refresh { color: #FFFFFF; font-weight: bold; }
.header-back { font-size: 28px; }
.header-refresh { font-size: 22px; }
.header-title { font-size: 17px; font-weight: bold; color: #FFFFFF; }
.stats-row { flex-direction: row; padding: 12px 8px; margin: 10px 12px; border-radius: 22px; }
.stat-card { flex: 1; align-items: center; padding: 4px 0; }
.stat-num { font-size: 20px; font-weight: bold; color: #DBC8ED; margin-bottom: 2px; }
.stat-label { font-size: 11px; color: rgba(255, 255, 255, 0.68); }
.tab-bar { flex-direction: row; margin: 0 12px 8px 12px; border-radius: 20px; overflow: hidden; }
.tab { flex: 1; padding: 12px 0; align-items: center; border-bottom-width: 3px; border-bottom-color: transparent; border-bottom-style: solid; }
.active { border-bottom-color: #DBC8ED; background-color: rgba(219, 200, 237, 0.12); }
.tab-text { font-size: 14px; color: rgba(255, 255, 255, 0.72); }
.log-scroll { flex: 1; padding: 8px 12px; }
.empty { align-items: center; padding: 40px 20px; }
.empty-text { font-size: 14px; color: rgba(255, 255, 255, 0.72); margin-bottom: 6px; }
.empty-hint { font-size: 12px; color: rgba(255, 255, 255, 0.52); }
.log-item { border-radius: 18px; padding: 12px; margin-bottom: 8px; }
.log-row1,
.log-row2,
.log-row3 { flex-direction: row; align-items: center; }
.log-row1 { margin-bottom: 4px; }
.log-row2 { margin-top: 2px; }
.log-row3 { margin-top: 4px; background-color: rgba(255, 255, 255, 0.08); border-radius: 12px; padding: 5px 8px; }
.log-time,
.log-field-label,
.log-level,
.section-header-text { color: rgba(255, 255, 255, 0.58); }
.log-time { font-size: 12px; margin-right: 8px; }
.log-tag,
.log-result,
.log-user-action,
.log-skip-reason { font-size: 11px; font-weight: bold; }
.log-tag { padding: 3px 7px; border-radius: 8px; background-color: rgba(255, 255, 255, 0.1); color: #FFFFFF; margin-right: 6px; }
.tag-app_duration { background-color: rgba(219, 200, 237, 0.18); color: #DBC8ED; }
.tag-manual { background-color: rgba(143, 240, 195, 0.12); color: #8FF0C3; }
.tag-scheduled { background-color: rgba(194, 224, 238, 0.14); color: #C2E0EE; }
.log-level,
.log-result { margin-left: auto; }
.res-completed,
.ua-completed,
.ua-self_reported { color: #8FF0C3; }
.res-self_reported { color: #C2E0EE; }
.res-skipped,
.ua-skipped { color: #FF8FA6; }
.res-feedback,
.ua-busy_remind_later,
.log-skip-reason { color: #DBC8ED; }
.ua-ignored,
.ua-timeout { color: rgba(255, 255, 255, 0.58); }
.log-field-label { font-size: 11px; }
.log-field-val { font-size: 12px; color: #FFFFFF; }
.section-header { padding: 12px 4px 4px 4px; }
.section-header-text { font-size: 13px; font-weight: bold; }
.db-table-card,
.config-item { border-radius: 16px; padding: 10px 12px; margin-bottom: 6px; }
.db-table-row,
.config-row { flex-direction: row; justify-content: space-between; align-items: center; }
.db-table-name,
.config-key { color: #FFFFFF; }
.db-table-name { font-size: 13px; }
.db-table-count { font-size: 13px; font-weight: bold; color: #DBC8ED; }
.config-key { font-size: 12px; flex: 1; }
.config-val { font-size: 12px; color: rgba(255, 255, 255, 0.72); text-align: right; max-width: 160px; }
.log-list { position: relative; z-index: 1; }
</style>
